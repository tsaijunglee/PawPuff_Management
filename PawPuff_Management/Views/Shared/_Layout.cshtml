<!doctype html>
<html lang="zh-Hant">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>PawPuff 噗爪 Admin 後台管理系統</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700&family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet">
    <link href="~/css/admin-dashboard.css" rel="stylesheet">
    <link href="~/css/member-management.css" rel="stylesheet">
    @RenderSection("Styles", required: false)
</head>

<body data-current-screen="@ViewData["CurrentScreen"]">
    <div class="admin-shell">
        <aside class="sidebar" id="sidebar">
            <div class="brand">
                <img src="~/img/Logo2.PNG" alt="PawPuff 噗爪">
            </div>

            <a class="home-link" asp-controller="Home" asp-action="Index" data-screen="dashboard" data-screen-title="儀錶板">
                <i class="bi bi-house-door-fill"></i>
                <span>儀錶板</span>
            </a>

            <nav class="sidebar-accordion" id="sidebarAccordion" aria-label="後台主選單">
                <section class="nav-group">
                    <button class="nav-heading collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#menuAccount" aria-expanded="false" aria-controls="menuAccount">
                        <i class="bi bi-person-circle main-icon"></i>
                        <span>帳號</span>
                        <i class="bi bi-chevron-down chevron"></i>
                    </button>
                    <ul class="side-nav collapse" id="menuAccount" data-bs-parent="#sidebarAccordion">
                        <li><a asp-controller="Users" asp-action="Index" data-screen="member-management" data-screen-title="會員管理"><i class="bi bi-person-circle"></i>會員管理</a></li>
                        <li><a asp-controller="Admins" asp-action="Index" data-screen="admin-management" data-screen-title="管理員管理"><i class="bi bi-people"></i>管理員管理</a></li>
                    </ul>
                </section>

                <section class="nav-group">
                    <button class="nav-heading collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#menuArticle" aria-expanded="false" aria-controls="menuArticle">
                        <i class="bi bi-file-earmark-text main-icon"></i>
                        <span>文章</span>
                        <i class="bi bi-chevron-down chevron"></i>
                    </button>
                    <ul class="side-nav collapse" id="menuArticle" data-bs-parent="#sidebarAccordion">
                        <li><a asp-controller="ArticleCategories" asp-action="Index" data-screen="article-category-management" data-screen-title="文章分類管理"><i class="bi bi-folder2-open"></i>文章分類管理</a></li>
                        <li><a asp-controller="Articles" asp-action="Index" data-screen="article-management" data-screen-title="文章管理"><i class="bi bi-file-earmark-text"></i>文章管理</a></li>
                    </ul>
                </section>

                <section class="nav-group">
                    <button class="nav-heading collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#menuShop" aria-expanded="false" aria-controls="menuShop">
                        <i class="bi bi-shop-window main-icon"></i>
                        <span>商城</span>
                        <i class="bi bi-chevron-down chevron"></i>
                    </button>
                    <ul class="side-nav collapse" id="menuShop" data-bs-parent="#sidebarAccordion">
                        <li><a asp-controller="Shop" asp-action="Index" data-screen="product-list" data-screen-title="商城管理"><i class="bi bi-shop"></i>商城管理</a></li>
                        <li><a asp-controller="OwnedProducts" asp-action="Index" data-screen="owned-product-list" data-screen-title="持有商品一覽"><i class="bi bi-bag-heart"></i>持有商品一覽</a></li>
                    </ul>
                </section>

                <section class="nav-group">
                    <button class="nav-heading collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#menuPoints" aria-expanded="false" aria-controls="menuPoints">
                        <i class="bi bi-coin main-icon"></i>
                        <span>點數</span>
                        <i class="bi bi-chevron-down chevron"></i>
                    </button>
                    <ul class="side-nav collapse" id="menuPoints" data-bs-parent="#sidebarAccordion">
                        <li><a asp-controller="PointRules" asp-action="Index" data-screen="point-rule-management" data-screen-title="規則管理"><i class="bi bi-coin"></i>規則管理</a></li>
                        <li><a asp-controller="Points" asp-action="Index" data-screen="point-management" data-screen-title="點數管理"><i class="bi bi-plus-slash-minus"></i>點數管理</a></li>
                    </ul>
                </section>

                <section class="nav-group">
                    <button class="nav-heading collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#menuDoll" aria-expanded="false" aria-controls="menuDoll">
                        <i class="bi bi-person-standing-dress main-icon"></i>
                        <span>紙娃娃</span>
                        <i class="bi bi-chevron-down chevron"></i>
                    </button>
                    <ul class="side-nav collapse" id="menuDoll" data-bs-parent="#sidebarAccordion">
                        <li><a asp-controller="OwnedCombinations" asp-action="Index" data-screen="owned-combination-list" data-screen-title="持有組合一覽"><i class="bi bi-layers"></i>持有組合一覽</a></li>
                        <li><a asp-controller="CombinationPreview" asp-action="Index" data-screen="combination-preview" data-screen-title="組合預覽"><i class="bi bi-person-standing-dress"></i>組合預覽</a></li>
                    </ul>
                </section>

                <section class="nav-group">
                    <button class="nav-heading collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#menuNotice" aria-expanded="false" aria-controls="menuNotice">
                        <i class="bi bi-bell main-icon"></i>
                        <span>通知</span>
                        <i class="bi bi-chevron-down chevron"></i>
                    </button>
                    <ul class="side-nav collapse" id="menuNotice" data-bs-parent="#sidebarAccordion">
                        <li><a asp-controller="Notifications" asp-action="Index" data-screen="send-notification" data-screen-title="發送通知"><i class="bi bi-send"></i>發送通知</a></li>
                    </ul>
                </section>

                <section class="nav-group">
                    <button class="nav-heading collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#menuSupport" aria-expanded="false" aria-controls="menuSupport">
                        <i class="bi bi-headset main-icon"></i>
                        <span>客服</span>
                        <i class="bi bi-chevron-down chevron"></i>
                    </button>
                    <ul class="side-nav collapse" id="menuSupport" data-bs-parent="#sidebarAccordion">
                        <li><a asp-controller="Faq" asp-action="Index" data-screen="faq" data-screen-title="問與答"><i class="bi bi-question-circle"></i>問與答</a></li>
                        @* <li><a href="./support-ticket.html" data-screen="support-ticket" data-screen-title="客服工單"><i class="bi bi-headset"></i>客服工單</a></li> *@
                    </ul>
                </section>
            </nav>

            <div class="sidebar-illustration" aria-hidden="true">
                <img src="~/img/LEFT.PNG" alt="">
            </div>
        </aside>

        <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

        <main class="main-area">
            <header class="app-header">
                <div class="d-flex align-items-center gap-3">
                    <button class="mobile-menu" type="button" id="sidebarToggle" aria-label="開啟側邊選單">
                        <i class="bi bi-list"></i>
                    </button>
                    <h1 class="page-title" id="pageTitleWrap">
                        <span class="title-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
                        <span id="pageTitleText">管理平台</span>
                    </h1>
                </div>

                <div class="header-actions">
                    <div class="notification-wrap">
                        <button class="icon-btn" type="button" id="notificationToggle" aria-label="通知" aria-expanded="false" aria-controls="notificationPanel">
                            <i class="bi bi-bell"></i>
                            <span class="notice-badge" id="notificationBadge">1</span>
                        </button>

                        <div class="notification-panel d-none" id="notificationPanel">
                            <div class="notification-head">
                                <h2 class="notification-title"><i class="bi bi-bell"></i>通知中心</h2>
                                <button class="mark-all-read" type="button" id="markAllRead">全部已讀</button>
                            </div>

                            <ul class="notification-list" aria-label="通知列表">
                                <li>
                                    <a class="notification-item is-unread" data-notification asp-controller="Articles" asp-action="Index">
                                        <span class="notification-dot" aria-hidden="true"></span>
                                        <span class="notification-meta"><span>文章</span><span>25 分鐘前</span></span>
                                        <span class="notification-name">有 3 篇文章尚未檢查</span>
                                        <span class="notification-jump">前往文章管理 <i class="bi bi-chevron-right"></i></span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="dropdown">
                        <button class="admin-toggle dropdown-toggle" type="button" id="adminMenuToggle" data-bs-toggle="dropdown" aria-expanded="false" aria-controls="adminMenu">
                            <span class="admin-avatar" aria-hidden="true">
                                <img src="~/img/ADMIN(2).PNG" alt="">
                            </span>
                            <span class="admin-name">Admin</span>
                            <i class="bi bi-chevron-down"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end admin-menu" id="adminMenu">
                            <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index" data-screen="profile-management" data-screen-title="修改個人資料"><i class="bi bi-person"></i>修改個人資料</a></li>
                            <li><hr class="dropdown-divider"></li>
                            @* <li><a class="dropdown-item" asp-controller="Auth" asp-action="Index"><i class="bi bi-box-arrow-right"></i>登出</a></li> *@
                            <li>
                                <form asp-controller="Auth"
                                      asp-action="Logout"
                                      method="post">
                                    <button type="submit"
                                            class="dropdown-item">
                                        <i class="bi bi-box-arrow-right"></i>
                                        登出
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            @RenderBody()

            <footer class="site-footer" id="dashboardFooter">
                <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
                <span>© 2024 PawPuff 噗爪 Admin 後台管理系統</span>
                <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            </footer>
        </main>
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-4">
        <div id="actionToast" class="toast align-items-center border-0" role="status" aria-live="polite" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body fw-bold text-brown" id="toastMessage">已完成操作</div>
                <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="關閉"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/member-management.js" asp-append-version="true" ></script>
    <script src="~/js/admin-dashboard.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
