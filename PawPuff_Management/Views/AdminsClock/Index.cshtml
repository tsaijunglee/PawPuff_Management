@model List<PawPuff_Management.Models.DTOs.AdminClockDto>


@{
    ViewData["Title"] = "所有員工打卡紀錄";
    ViewData["CurrentScreen"] = "dashboard2";
}

<div class="dashboard-content management-screen" id="managementScreen" data-screen-panel="management">
    <section class="soft-panel management-panel">
        <span class="screen-kicker">
            <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            PawPuff Admin
        </span>
        <h2 class="screen-title" id="managementTitle">所有員工打卡紀錄</h2>
        <p class="screen-desc" id="managementDescription">
            檢視所有管理員的上下班打卡紀錄。
        </p>

        <div class="member-page-actions attendance-page-actions">
            @* <a class="member-create-open-btn" href="./admin-dashboard.html"> *@
            <a asp-controller="Home" asp-action="Index" class="member-create-open-btn" data-screen="dashboard">
                <i class="bi bi-arrow-left-circle"></i>返回儀表板
            </a>
        </div>

        <div class="attendance-records-view" id="attendanceRecordsView">
            <form class="member-search-panel" id="attendanceRecordsSearchForm">
                <div class="member-search-row attendance-search-row">
                    <div class="member-search-field">
                        <label class="form-label" for="attendanceRecordsFilterAdmin">帳號</label>
                        <input class="form-control" id="attendanceRecordsFilterAdmin" type="text" data-attendance-record-filter="admin" placeholder="輸入帳號">
                    </div>
                    <div class="member-search-field">
                        <label class="form-label" for="attendanceRecordsFilterDate">日期</label>
                        <input class="form-control attendance-date-input" id="attendanceRecordsFilterDate" type="date" data-attendance-record-filter="date">
                    </div>
                    <div class="member-search-field">
                        <button class="member-reset-btn px-3" id="attendanceRecordsFilterReset" type="button">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>重設
                        </button>
                    </div>
                </div>
            </form>

            <div class="member-table-card">
                <div class="member-table-toolbar">
                    <strong><i class="bi bi-card-list me-2"></i>所有員工打卡紀錄一覽</strong>
                    <span class="member-count" id="attendanceRecordsResultCount">共 0 筆</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover member-table attendance-table attendance-records-table align-middle">
                        <thead>
                            <tr>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-attendance-record-sort="admin">帳號 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-attendance-record-sort="date">日期 <i class="bi bi-sort-down"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-attendance-record-sort="clockIn">上班時間 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-attendance-record-sort="clockOut">下班時間 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                            </tr>
                        </thead>

                        <tbody id="attendanceRecordsTableBody">
                            @foreach (var record in Model)
                            {
                                <tr data-attendance-record-row
                                    data-admin="@record.AdminAccount"
                                    data-date-key="@record.WorkDate.ToString("yyyy-MM-dd")"
                                    data-work-date="@record.WorkDate.ToString("yyyy/M/d")"
                                    data-clock-in="@record.ClockInTime.ToString("HH:mm")"
                                    data-clock-out="@(record.ClockOutTime?.ToString("HH:mm") ?? "")">

                                    <td>@record.AdminAccount</td>

                                    <td>
                                        @record.WorkDate.ToString("yyyy/M/d")
                                    </td>

                                    <td>
                                        @record.ClockInTime.ToString("HH:mm")
                                    </td>

                                    <td>
                                        @(record.ClockOutTime?.ToString("HH:mm")
                                                                  ?? "尚未打卡")
                                </td>
                            </tr>
                                                        }
                        </tbody>

