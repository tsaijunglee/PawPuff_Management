@model PawPuff_Management.Models.ViewModels.OwnedCombinationsIndexViewModel

@{
    ViewData["Title"] = "持有組合一覽";
    ViewData["CurrentScreen"] = "owned-combination-list";
}

<div class="dashboard-content management-screen" id="managementScreen" data-screen-panel="management">
    <section class="soft-panel management-panel">
        <span class="screen-kicker">
            <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            PawPuff Admin
        </span>
        <h2 class="screen-title" id="managementTitle">持有組合一覽</h2>
        <p class="screen-desc" id="managementDescription">
            檢視帳號儲存的紙娃娃穿搭組合。
        </p>
        <div class="owned-combination-view"
             id="ownedCombinationView"
             data-body-sort-order="@Model.BodySortOrder">
            <form class="member-search-panel"
                  id="ownedCombinationSearchForm">
                <div class="member-search-row owned-combination-search-row">
                    <div class="member-search-field">
                        <label class="form-label"
                               for="ownedCombinationFilterAccount">
                            帳號
                        </label>
                        <input class="form-control"
                               id="ownedCombinationFilterAccount"
                               type="text"
                               data-owned-combination-filter="account"
                               placeholder="輸入帳號">
                    </div>

                    <div class="member-search-field">
                        <label class="form-label"
                               for="ownedCombinationFilterBody">
                            底圖名
                        </label>
                        <input class="form-control"
                               id="ownedCombinationFilterBody"
                               type="text"
                               data-owned-combination-filter="body"
                               placeholder="輸入底圖名">
                    </div>

                    <div class="member-search-field">
                        <label class="form-label"
                               for="ownedCombinationFilterAccessory">
                            配件圖名
                        </label>
                        <input class="form-control"
                               id="ownedCombinationFilterAccessory"
                               type="text"
                               data-owned-combination-filter="accessory"
                               placeholder="輸入配件圖名">
                    </div>

                    <div class="member-search-field">
                        <label class="form-label"
                               for="ownedCombinationFilterColor">
                            染劑名
                        </label>
                        <input class="form-control"
                               id="ownedCombinationFilterColor"
                               type="text"
                               data-owned-combination-filter="color"
                               placeholder="輸入染劑名或色碼">
                    </div>

                    <div class="member-search-field">
                        <button class="member-reset-btn px-3"
                                id="ownedCombinationFilterReset"
                                type="button">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>重設
                        </button>
                    </div>
                </div>
            </form>

            <div class="member-table-card">
                <div class="member-table-toolbar">
                    <strong>
                        <i class="bi bi-layers me-2"></i>持有組合資料表
                    </strong>
                    <span class="member-count"
                          id="ownedCombinationResultCount">
                        共 @Model.TotalCount 筆
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover member-table owned-combination-table align-middle">
                        <thead>
                            <tr>
                                <th scope="col">
                                    <button class="sort-btn"
                                            type="button"
                                            data-owned-combination-sort="id">
                                        編號 <i class="bi bi-sort-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn"
                                            type="button"
                                            data-owned-combination-sort="account">
                                        帳號 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <span class="sort-static-label">組合圖</span>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn"
                                            type="button"
                                            data-owned-combination-sort="body">
                                        底圖與染劑名 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn"
                                            type="button"
                                            data-owned-combination-sort="accessory1">
                                        配件圖1與染劑名 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn"
                                            type="button"
                                            data-owned-combination-sort="accessory2">
                                        配件圖2與染劑名 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn"
                                            type="button"
                                            data-owned-combination-sort="accessory3">
                                        配件圖3與染劑名 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                            </tr>
                        </thead>

                        <tbody id="ownedCombinationTableBody">
                            @foreach (var item in Model.Items)
                            {
                                <tr data-owned-combination-row
                                    data-id="@item.Id"
                                    data-account="@item.UserAccount"
                                    data-body-name="@item.Body.Name"
                                    data-body-image-name="@item.Body.ImageName"
                                    data-body-image-url="@item.Body.ImageUrl"
                                    data-body-color-name="@(item.BodyColor?.Name ?? string.Empty)"
                                    data-body-color-hex="@(item.BodyColor?.HexCode ?? string.Empty)"
                                    data-accessory1-name="@(item.Accessory1?.Name ?? string.Empty)"
                                    data-accessory1-line-name="@(item.Accessory1?.LineImageName ?? string.Empty)"
                                    data-accessory1-line-url="@(item.Accessory1?.LineImageUrl ?? string.Empty)"
                                    data-accessory1-mask-name="@(item.Accessory1?.MaskImageName ?? string.Empty)"
                                    data-accessory1-mask-url="@(item.Accessory1?.MaskImageUrl ?? string.Empty)"
                                    data-accessory1-sort-order="@(item.Accessory1?.SortOrder ?? 0)"
                                    data-accessory1-color-name="@(item.Accessory1?.Color?.Name ?? string.Empty)"
                                    data-accessory1-color-hex="@(item.Accessory1?.Color?.HexCode ?? string.Empty)"
                                    data-accessory2-name="@(item.Accessory2?.Name ?? string.Empty)"
                                    data-accessory2-line-name="@(item.Accessory2?.LineImageName ?? string.Empty)"
                                    data-accessory2-line-url="@(item.Accessory2?.LineImageUrl ?? string.Empty)"
                                    data-accessory2-mask-name="@(item.Accessory2?.MaskImageName ?? string.Empty)"
                                    data-accessory2-mask-url="@(item.Accessory2?.MaskImageUrl ?? string.Empty)"
                                    data-accessory2-sort-order="@(item.Accessory2?.SortOrder ?? 0)"
                                    data-accessory2-color-name="@(item.Accessory2?.Color?.Name ?? string.Empty)"
                                    data-accessory2-color-hex="@(item.Accessory2?.Color?.HexCode ?? string.Empty)"
                                    data-accessory3-name="@(item.Accessory3?.Name ?? string.Empty)"
                                    data-accessory3-line-name="@(item.Accessory3?.LineImageName ?? string.Empty)"
                                    data-accessory3-line-url="@(item.Accessory3?.LineImageUrl ?? string.Empty)"
                                    data-accessory3-mask-name="@(item.Accessory3?.MaskImageName ?? string.Empty)"
                                    data-accessory3-mask-url="@(item.Accessory3?.MaskImageUrl ?? string.Empty)"
                                    data-accessory3-sort-order="@(item.Accessory3?.SortOrder ?? 0)"
                                    data-accessory3-color-name="@(item.Accessory3?.Color?.Name ?? string.Empty)"
                                    data-accessory3-color-hex="@(item.Accessory3?.Color?.HexCode ?? string.Empty)">
                                    <td data-owned-combination-cell="id">
                                        @item.Id
                                    </td>
                                    <td data-owned-combination-cell="account">
                                        @item.UserAccount
                                    </td>
                                    <td>
                                        <div class="combination-thumb"
                                             data-owned-combination-preview>
                                            <canvas class="combination-thumb-canvas d-none"
                                                    data-owned-combination-canvas
                                                    aria-label="@item.UserAccount 的紙娃娃組合圖">
                                            </canvas>
                                            <span class="combination-thumb-status"
                                                  data-owned-combination-status>
                                                等待載入
                                            </span>
                                        </div>
                                    </td>
                                    <td data-owned-combination-cell="body">
                                        <div class="combination-slot">
                                            <strong>@item.Body.Name</strong>
                                            @if (item.BodyColor is null)
                                            {
                                                <span class="combination-null"
                                                      aria-label="NULL">—</span>
                                            }
                                            else
                                            {
                                                <span class="combination-color-value"
                                                      data-combination-color-chip
                                                      data-color="@(item.BodyColor.HexCode ?? string.Empty)">
                                                    <i aria-hidden="true"></i>
                                                    @item.BodyColor.Name
                                                </span>
                                            }
                                        </div>
                                    </td>
                                    <td data-owned-combination-cell="accessory1">
                                        @if (item.Accessory1 is null)
                                        {
                                            <span class="combination-null"
                                                  aria-label="NULL">—</span>
                                        }
                                        else
                                        {
                                            <div class="combination-slot">
                                                <strong>@item.Accessory1.Name</strong>
                                                @if (item.Accessory1.Color is null)
                                                {
                                                    <span class="combination-null"
                                                          aria-label="NULL">—</span>
                                                }
                                                else
                                                {
                                                    <span class="combination-color-value"
                                                          data-combination-color-chip
                                                          data-color="@(item.Accessory1.Color.HexCode ?? string.Empty)">
                                                        <i aria-hidden="true"></i>
                                                        @item.Accessory1.Color.Name
                                                    </span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td data-owned-combination-cell="accessory2">
                                        @if (item.Accessory2 is null)
                                        {
                                            <span class="combination-null"
                                                  aria-label="NULL">—</span>
                                        }
                                        else
                                        {
                                            <div class="combination-slot">
                                                <strong>@item.Accessory2.Name</strong>
                                                @if (item.Accessory2.Color is null)
                                                {
                                                    <span class="combination-null"
                                                          aria-label="NULL">—</span>
                                                }
                                                else
                                                {
                                                    <span class="combination-color-value"
                                                          data-combination-color-chip
                                                          data-color="@(item.Accessory2.Color.HexCode ?? string.Empty)">
                                                        <i aria-hidden="true"></i>
                                                        @item.Accessory2.Color.Name
                                                    </span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td data-owned-combination-cell="accessory3">
                                        @if (item.Accessory3 is null)
                                        {
                                            <span class="combination-null"
                                                  aria-label="NULL">—</span>
                                        }
                                        else
                                        {
                                            <div class="combination-slot">
                                                <strong>@item.Accessory3.Name</strong>
                                                @if (item.Accessory3.Color is null)
                                                {
                                                    <span class="combination-null"
                                                          aria-label="NULL">—</span>
                                                }
                                                else
                                                {
                                                    <span class="combination-color-value"
                                                          data-combination-color-chip
                                                          data-color="@(item.Accessory3.Color.HexCode ?? string.Empty)">
                                                        <i aria-hidden="true"></i>
                                                        @item.Accessory3.Color.Name
                                                    </span>
                                                }
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="member-pagination-wrap">
                    <span class="member-page-info"
                          id="ownedCombinationPageInfo">
                        第 1 頁
                    </span>
                    <nav aria-label="持有組合表格分頁">
                        <ul class="pagination member-pagination"
                            id="ownedCombinationPagination"></ul>
                    </nav>
                </div>
            </div>
        </div>
    </section>
</div>

@section Styles {
    <link href="~/css/owned-combination-list.css" rel="stylesheet" asp-append-version="true">
}

@section Scripts {
    <script src="~/js/owned-combination-list.js" asp-append-version="true"></script>
}
