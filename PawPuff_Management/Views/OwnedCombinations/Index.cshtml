@{
    ViewData["Title"] = "持有組合一覽";
    ViewData["CurrentScreen"] = "owned-combination-list";
}

<div class="dashboard-content management-screen" id="managementScreen" data-screen-panel="management">
    <section class="soft-panel management-panel">
        <span class="screen-kicker">
            <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            PawPuff Admin
        </span>
        <h2 class="screen-title" id="managementTitle">持有組合一覽</h2>
        <p class="screen-desc" id="managementDescription">
            檢視帳號儲存的紙娃娃穿搭組合。
        </p>
        <div class="owned-combination-view" id="ownedCombinationView">
            <form class="member-search-panel" id="ownedCombinationSearchForm">
                <div class="member-search-row owned-combination-search-row">
                    <div class="member-search-field">
                        <label class="form-label" for="ownedCombinationFilterAccount">帳號</label>
                        <input class="form-control" id="ownedCombinationFilterAccount" type="text" data-owned-combination-filter="account" placeholder="輸入帳號">
                    </div>
                    <div class="member-search-field">
                        <label class="form-label" for="ownedCombinationFilterBody">底圖名</label>
                        <input class="form-control" id="ownedCombinationFilterBody" type="text" data-owned-combination-filter="body" placeholder="輸入底圖名">
                    </div>
                    <div class="member-search-field">
                        <label class="form-label" for="ownedCombinationFilterAccessory">配件圖名</label>
                        <input class="form-control" id="ownedCombinationFilterAccessory" type="text" data-owned-combination-filter="accessory" placeholder="輸入配件圖名">
                    </div>
                    <div class="member-search-field">
                        <label class="form-label" for="ownedCombinationFilterColor">染劑名</label>
                        <input class="form-control" id="ownedCombinationFilterColor" type="text" data-owned-combination-filter="color" placeholder="輸入染劑名">
                    </div>
                    <div class="member-search-field">
                        <button class="member-reset-btn px-3" id="ownedCombinationFilterReset" type="button">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>重設
                        </button>
                    </div>
                </div>
            </form>

            <div class="member-table-card">
                <div class="member-table-toolbar">
                    <strong><i class="bi bi-layers me-2"></i>持有組合資料表</strong>
                    <span class="member-count" id="ownedCombinationResultCount">共 0 筆</span>
                </div>
