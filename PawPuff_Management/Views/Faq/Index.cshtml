@using PawPuff_Management.Models.Infra
@model List<PawPuff_Management.Models.DTOs.FaqListItemDto>
@{
    ViewData["Title"] = "問與答";
    ViewData["CurrentScreen"] = "faq";
}

@* AJAX 需要的防偽權杖,faq-management.js 會抓這個 input 的值 *@
@Html.AntiForgeryToken()

<div class="dashboard-content management-screen" id="managementScreen" data-screen-panel="management"
     data-faq-list-url="@Url.Action("List", "Faq")"
     data-faq-save-url="@Url.Action("Save", "Faq")"
     data-faq-toggle-url="@Url.Action("ToggleActive", "Faq")">
    <section class="soft-panel management-panel">
        <span class="screen-kicker">
            <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            PawPuff Admin
        </span>
        <h2 class="screen-title" id="managementTitle">問與答</h2>
        <p class="screen-desc" id="managementDescription">
            管理客服問與答內容、分類與顯示狀態。
        </p>
        <div class="faq-management-view" id="faqManagementView">
            <div class="member-page-actions faq-page-actions">
                <button class="member-create-open-btn" id="faqCreateOpen" type="button" data-bs-toggle="modal" data-bs-target="#faqCreateModal">
                    <i class="bi bi-plus-circle me-1"></i>新增問答
                </button>
            </div>

            <form class="member-search-panel" id="faqSearchForm">
                <div class="member-search-row faq-search-row">
                    <div class="member-search-field">
                        <label class="form-label" for="faqFilterType">類型</label>
                        <select class="form-select faq-filter-select" id="faqFilterType" data-faq-filter="type">
                            <option value="">全部</option>
                            @foreach (FaqType item in Enum.GetValues<FaqType>())
                            {
                                @* 篩選是前端比對 data-type,所以 value 維持中文名稱 *@
                                <option value="@item.ToDisplayName()">@item.ToDisplayName()</option>
                            }
                        </select>
                    </div>
                    <div class="member-search-field is-wide faq-text-filter-field">
                        <label class="form-label" for="faqFilterQuestion">問題</label>
                        <input class="form-control" id="faqFilterQuestion" type="text" data-faq-filter="question" placeholder="輸入問題關鍵字">
                    </div>
                    <div class="member-search-field is-wide faq-text-filter-field">
                        <label class="form-label" for="faqFilterAnswer">答案</label>
                        <input class="form-control" id="faqFilterAnswer" type="text" data-faq-filter="answer" placeholder="輸入答案關鍵字">
                    </div>
                    <div class="member-search-field">
                        <button class="member-reset-btn px-3" id="faqFilterReset" type="button">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>重設
                        </button>
                    </div>
                </div>
            </form>

            <div class="member-table-card faq-table-card">
                <div class="member-table-toolbar">
                    <strong><i class="bi bi-question-circle me-2"></i>問與答資料表</strong>
                    <span class="member-count" id="faqResultCount">共 @Model.Count 筆</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover member-table faq-table align-middle">
                        <thead>
                            <tr>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-faq-sort="sortOrder">排序 <i class="bi bi-sort-down"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-faq-sort="type">類型 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-faq-sort="question">問題 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col"><span class="sort-static-label">答案</span></th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-faq-sort="updatedAt">最後更新時間 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-faq-sort="active">停用/啟用 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col"><span class="sort-static-label">操作</span></th>
                            </tr>
                        </thead>
                        <tbody id="faqTableBody">
@if (Model.Count == 0)
{
                            <tr class="faq-empty-row" data-faq-empty="true">
                                <td colspan="7">目前沒有問與答資料</td>
                            </tr>
}
else
{
    foreach (var item in Model)
    {
                            <tr data-faq-row
                                data-faq-id="@item.Id"
                                data-type="@item.TypeName"
                                data-type-value="@item.Type"
                                data-question="@item.Question"
                                data-answer="@item.Answer"
                                data-sort-order="@item.SortOrder"
                                data-active="@(item.IsActive ? "true" : "false")"
                                data-created-at="@item.CreatedAtText"
                                data-updated-at="@item.UpdatedAtText">
                                <td data-faq-cell="sortOrder">@item.SortOrder</td>
                                <td data-faq-cell="type">@item.TypeName</td>
                                <td data-faq-cell="question">@item.Question</td>
                                <td class="faq-answer-cell" data-faq-cell="answer">@item.Answer</td>
                                <td data-faq-cell="updatedAt">@item.UpdatedAtText</td>
                                <td>
                                    <div class="form-check form-switch member-status-switch faq-status-switch">
                                        <input class="form-check-input" id="faqStatus@(item.Id)" type="checkbox" role="switch"
                                               data-faq-status="@item.Id" checked="@item.IsActive">
                                        <label class="member-status-text" for="faqStatus@(item.Id)">@(item.IsActive ? "啟用" : "停用")</label>
                                    </div>
                                </td>
                                <td>
                                    <button class="member-detail-btn faq-edit-btn" type="button" data-faq-edit="@item.Id">
                                        <i class="bi bi-pencil-square"></i>編輯
                                    </button>
                                </td>
                            </tr>
    }
}
                        </tbody>
                    </table>
                </div>
                <div class="member-pagination-wrap">
                    <span class="member-page-info" id="faqPageInfo">第 1 頁</span>
                    <nav aria-label="問與答表格分頁">
                        <ul class="pagination member-pagination" id="faqPagination"></ul>
                    </nav>
                </div>
            </div>
        </div>
    </section>
</div>

<div class="modal fade" id="faqCreateModal" tabindex="-1" aria-labelledby="faqCreateModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content member-form-modal">
            <form id="faqCreateForm" novalidate>
                <div class="modal-header">
                    <h5 class="modal-title" id="faqCreateModalTitle">新增問答</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="faqCreateType">類型</label>
                            <select class="form-select faq-modal-select" id="faqCreateType" required>
                                <option value="">請選擇</option>
                                @foreach (FaqType item in Enum.GetValues<FaqType>())
                                {
                                    @* 這裡的 value 是要送進資料庫的數字 *@
                                    <option value="@((int)item)">@item.ToDisplayName()</option>
                                }
                            </select>
                            <div class="invalid-feedback">請選擇類型。</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="faqCreateSortOrder">排序</label>
                            <input class="form-control" id="faqCreateSortOrder" type="number" min="1" step="1" required>
                            <div class="invalid-feedback">請輸入大於 0 的排序數字。</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="faqCreateQuestion">問題</label>
                            <input class="form-control" id="faqCreateQuestion" type="text" maxlength="100" required>
                            <div class="invalid-feedback">請輸入問題內容。</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="faqCreateAnswer">答案</label>
                            <textarea class="form-control faq-answer-textarea" id="faqCreateAnswer" rows="7" maxlength="1000" required></textarea>
                            <div class="invalid-feedback">請輸入答案內容。</div>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch member-status-switch faq-modal-status-switch">
                                <input class="form-check-input" id="faqCreateActive" type="checkbox" role="switch" checked>
                                <label class="member-status-text" for="faqCreateActive">啟用</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-warning fw-bold text-brown">新增問答</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="faqEditModal" tabindex="-1" aria-labelledby="faqEditModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content member-form-modal">
            <form id="faqEditForm" novalidate>
                <div class="modal-header">
                    <h5 class="modal-title" id="faqEditModalTitle">編輯問答</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
                </div>
                <div class="modal-body">
                    <input id="faqEditId" type="hidden">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="faqEditType">類型</label>
                            <select class="form-select faq-modal-select" id="faqEditType" required>
                                <option value="">請選擇</option>
                                @foreach (FaqType item in Enum.GetValues<FaqType>())
                                {
                                    <option value="@((int)item)">@item.ToDisplayName()</option>
                                }
                            </select>
                            <div class="invalid-feedback">請選擇類型。</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="faqEditSortOrder">排序</label>
                            <input class="form-control" id="faqEditSortOrder" type="number" min="1" step="1" required>
                            <div class="invalid-feedback">請輸入大於 0 的排序數字。</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="faqEditQuestion">問題</label>
                            <input class="form-control" id="faqEditQuestion" type="text" maxlength="100" required>
                            <div class="invalid-feedback">請輸入問題內容。</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="faqEditAnswer">答案</label>
                            <textarea class="form-control faq-answer-textarea" id="faqEditAnswer" rows="7" maxlength="1000" required></textarea>
                            <div class="invalid-feedback">請輸入答案內容。</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-warning fw-bold text-brown">儲存修改</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="faqStatusModal" tabindex="-1" aria-labelledby="faqStatusModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content member-status-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="faqStatusModalTitle">確認變更狀態</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <p class="member-status-modal-desc mb-0" id="faqStatusModalDescription">確定要變更此問答狀態嗎？</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-warning fw-bold text-brown" id="faqStatusConfirm">確認變更</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/css/faq-management.css" rel="stylesheet" asp-append-version="true">
}

@section Scripts {
    <script src="~/js/faq-management.js" asp-append-version="true"></script>
}
