@{
    ViewData["Title"] = "問與答";
    ViewData["CurrentScreen"] = "faq";
}

<div class="dashboard-content management-screen" id="managementScreen" data-screen-panel="management">
    <section class="soft-panel management-panel">
        <span class="screen-kicker">
            <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            PawPuff Admin
        </span>
        <h2 class="screen-title" id="managementTitle">問與答</h2>
        <p class="screen-desc" id="managementDescription">
            管理客服問與答內容、分類與顯示狀態。
        </p>
        <div class="faq-management-view" id="faqManagementView">
            <div class="member-page-actions faq-page-actions">
                <button class="member-create-open-btn" id="faqCreateOpen" type="button" data-bs-toggle="modal" data-bs-target="#faqCreateModal">
                    <i class="bi bi-plus-circle me-1"></i>新增問答
                </button>
            </div>

            <form class="member-search-panel" id="faqSearchForm">
                <div class="member-search-row faq-search-row">
                    <div class="member-search-field">
                        <label class="form-label" for="faqFilterType">類型</label>
                        <select class="form-select faq-filter-select" id="faqFilterType" data-faq-filter="type">
                            <option value="">全部</option>
                            <option value="帳號">帳號</option>
                            <option value="文章">文章</option>
                            <option value="商城">商城</option>
                            <option value="點數">點數</option>
                            <option value="紙娃娃">紙娃娃</option>
                            <option value="客服">客服</option>
                        </select>
                    </div>
                    <div class="member-search-field is-wide faq-text-filter-field">
                        <label class="form-label" for="faqFilterQuestion">問題</label>
                        <input class="form-control" id="faqFilterQuestion" type="text" data-faq-filter="question" placeholder="輸入問題關鍵字">
                    </div>
                    <div class="member-search-field is-wide faq-text-filter-field">
                        <label class="form-label" for="faqFilterAnswer">答案</label>
                        <input class="form-control" id="faqFilterAnswer" type="text" data-faq-filter="answer" placeholder="輸入答案關鍵字">
                    </div>
                    <div class="member-search-field">
                        <button class="member-reset-btn px-3" id="faqFilterReset" type="button">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>重設
                        </button>
                    </div>
                </div>
            </form>

            <div class="member-table-card faq-table-card">
                <div class="member-table-toolbar">
                    <strong><i class="bi bi-question-circle me-2"></i>問與答資料表</strong>
                    <span class="member-count" id="faqResultCount">共 0 筆</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover member-table faq-table align-middle">
                        <thead>
                            <tr>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-faq-sort="sortOrder">排序 <i class="bi bi-sort-down"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-faq-sort="type">類型 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-faq-sort="question">問題 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col"><span class="sort-static-label">答案</span></th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-faq-sort="updatedAt">最後更新時間 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-faq-sort="active">停用/啟用 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col"><span class="sort-static-label">操作</span></th>
                            </tr>
                        </thead>
                        <tbody id="faqTableBody">
                            <tr data-faq-row data-faq-id="1" data-type="帳號" data-question="忘記密碼怎麼辦？" data-answer="若您使用一般帳號登入，請於登入頁面點選「忘記密碼」，系統會寄送密碼重設信至您已驗證的 Email，請依照信件指示完成密碼重設。若您是使用 Google 或 LINE 登入，請至對應平台修改登入資訊後再重新登入 PawPuff。若超過 10 分鐘仍未收到信件，請先檢查垃圾郵件或促銷信件匣。若仍無法解決，請來信 pawpuff.officer@gmail.com。" data-sort-order="1" data-active="false" data-created-at="2026-01-15 13:00:00" data-updated-at="2026-04-15 15:20:00">
                                <td data-faq-cell="sortOrder">1</td>
                                <td data-faq-cell="type">帳號</td>
                                <td data-faq-cell="question">忘記密碼怎麼辦？</td>
                                <td class="faq-answer-cell" data-faq-cell="answer">若您使用一般帳號登入，請於登入頁面點選「忘記密碼」，系統會寄送密碼重設信至您已驗證的 Email，請依照信件指示完成密碼重設。若您是使用 Google 或 LINE 登入，請至對應平台修改登入資訊後再重新登入 PawPuff。若超過 10 分鐘仍未收到信件，請先檢查垃圾郵件或促銷信件匣。若仍無法解決，請來信 pawpuff.officer@gmail.com。</td>
                                <td data-faq-cell="updatedAt">2026-04-15 15:20:00</td>
                                <td>
                                    <div class="form-check form-switch member-status-switch faq-status-switch">
                                        <input class="form-check-input" id="faqStatus1" type="checkbox" role="switch" data-faq-status="1">
                                        <label class="member-status-text" for="faqStatus1">停用</label>
                                    </div>
                                </td>
                                <td>
                                    <button class="member-detail-btn faq-edit-btn" type="button" data-faq-edit="1">
                                        <i class="bi bi-pencil-square"></i>編輯
                                    </button>
                                </td>
                            </tr>
                            <tr data-faq-row data-faq-id="2" data-type="帳號" data-question="如何修改 Email 或手機號碼？" data-answer="請至「會員中心 → 個人資料」修改 Email 或手機號碼。修改後需要重新完成驗證，驗證成功後才會正式更新資料。若新的 Email 或手機已被其他帳號使用，系統將無法修改。若您無法完成驗證或帳號遭他人使用，請聯絡官方客服 pawpuff.officer@gmail.com。" data-sort-order="2" data-active="true" data-created-at="2026-01-22 13:23:00" data-updated-at="2026-01-23 14:21:00">
                                <td data-faq-cell="sortOrder">2</td>
                                <td data-faq-cell="type">帳號</td>
                                <td data-faq-cell="question">如何修改 Email 或手機號碼？</td>
                                <td class="faq-answer-cell" data-faq-cell="answer">請至「會員中心 → 個人資料」修改 Email 或手機號碼。修改後需要重新完成驗證，驗證成功後才會正式更新資料。若新的 Email 或手機已被其他帳號使用，系統將無法修改。若您無法完成驗證或帳號遭他人使用，請聯絡官方客服 pawpuff.officer@gmail.com。</td>
                                <td data-faq-cell="updatedAt">2026-01-23 14:21:00</td>
                                <td>
                                    <div class="form-check form-switch member-status-switch faq-status-switch">
                                        <input class="form-check-input" id="faqStatus2" type="checkbox" role="switch" data-faq-status="2" checked>
                                        <label class="member-status-text" for="faqStatus2">啟用</label>
                                    </div>
                                </td>
                                <td>
                                    <button class="member-detail-btn faq-edit-btn" type="button" data-faq-edit="2">
                                        <i class="bi bi-pencil-square"></i>編輯
                                    </button>
                                </td>
                            </tr>
                            <tr data-faq-row data-faq-id="3" data-type="文章" data-question="為什麼我的文章被隱藏或刪除？" data-answer="PawPuff 致力於維護友善的社群環境。若文章涉及不當言論、騷擾、洗版、廣告、侵犯著作權、違反法律或社群規範，管理員可能將文章隱藏或移除。若您認為是誤判，可向客服提出申訴，我們將再次審核您的文章內容。請來信 pawpuff.officer@gmail.com。" data-sort-order="3" data-active="true" data-created-at="2026-01-22 9:21:00" data-updated-at="NULL">
                                <td data-faq-cell="sortOrder">3</td>
                                <td data-faq-cell="type">文章</td>
                                <td data-faq-cell="question">為什麼我的文章被隱藏或刪除？</td>
                                <td class="faq-answer-cell" data-faq-cell="answer">PawPuff 致力於維護友善的社群環境。若文章涉及不當言論、騷擾、洗版、廣告、侵犯著作權、違反法律或社群規範，管理員可能將文章隱藏或移除。若您認為是誤判，可向客服提出申訴，我們將再次審核您的文章內容。請來信 pawpuff.officer@gmail.com。</td>
                                <td data-faq-cell="updatedAt">2026-01-22 9:21:00</td>
                                <td>
