@model PawPuff_Management.Models.ViewModels.OwnedProductsIndexViewModel

@{
    ViewData["Title"] = "持有商品一覽";
    ViewData["CurrentScreen"] = "owned-product-list";
}

<div class="dashboard-content management-screen" id="managementScreen" data-screen-panel="management">
    <section class="soft-panel management-panel">
        <span class="screen-kicker">
            <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            PawPuff Admin
        </span>
        <h2 class="screen-title" id="managementTitle">持有商品一覽</h2>
        <p class="screen-desc" id="managementDescription">
            檢視帳號持有的紙娃娃商品。
        </p>

        <div class="owned-product-view" id="ownedProductView">
            <form class="member-search-panel"
                  id="ownedProductSearchForm">
                <div class="member-search-row owned-product-search-row">
                    <div class="member-search-field">
                        <label class="form-label"
                               for="ownedProductFilterId">
                            編號
                        </label>
                        <input class="form-control"
                               id="ownedProductFilterId"
                               type="text"
                               inputmode="numeric"
                               data-owned-product-filter="id"
                               placeholder="輸入編號">
                    </div>

                    <div class="member-search-field">
                        <label class="form-label"
                               for="ownedProductFilterAccount">
                            帳號
                        </label>
                        <input class="form-control"
                               id="ownedProductFilterAccount"
                               type="text"
                               data-owned-product-filter="account"
                               placeholder="輸入帳號">
                    </div>

                    <div class="member-search-field is-wide">
                        <label class="form-label"
                               for="ownedProductFilterName">
                            商品名
                        </label>
                        <input class="form-control"
                               id="ownedProductFilterName"
                               type="text"
                               data-owned-product-filter="name"
                               placeholder="輸入商品名">
                    </div>

                    <div class="member-search-field">
                        <label class="form-label"
                               for="ownedProductFilterType">
                            商品類型
                        </label>
                        <select class="form-select owned-product-filter-select"
                                id="ownedProductFilterType"
                                data-owned-product-filter="type">
                            <option value="">全部</option>
                            @foreach (var productType in Model.ProductTypes)
                            {
                                <option value="@productType.Value">
                                    @productType.Text
                                </option>
                            }
                        </select>
                    </div>

                    <div class="member-search-field">
                        <button class="member-reset-btn px-3"
                                id="ownedProductFilterReset"
                                type="button">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>重設
                        </button>
                    </div>
                </div>
            </form>

            <div class="member-table-card">
                <div class="member-table-toolbar">
                    <strong>
                        <i class="bi bi-bag-heart me-2"></i>持有商品資料表
                    </strong>
                    <span class="member-count"
                          id="ownedProductResultCount">
                        共 @Model.TotalCount 筆
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover member-table owned-product-table align-middle">
                        <thead>
                            <tr>
                                <th scope="col">
                                    <button class="sort-btn"
                                            type="button"
                                            data-owned-product-sort="id">
                                        編號 <i class="bi bi-sort-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn"
                                            type="button"
                                            data-owned-product-sort="account">
                                        帳號 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <span class="sort-static-label">商品圖</span>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn"
                                            type="button"
                                            data-owned-product-sort="name">
                                        商品名稱 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn"
                                            type="button"
                                            data-owned-product-sort="type">
                                        商品類型 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn"
                                            type="button"
                                            data-owned-product-sort="purchasedAt">
                                        購買時間 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn"
                                            type="button"
                                            data-owned-product-sort="price">
                                        價格快照 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                            </tr>
                        </thead>

                        <tbody id="ownedProductTableBody">
                            @foreach (var item in Model.Items)
                            {
                                <tr data-owned-product-row
                                    data-id="@item.Id"
                                    data-account="@item.UserAccount"
                                    data-name="@item.ProductName"
                                    data-type="@item.ProductType"
                                    data-purchased-at="@item.BoughtAtDisplay"
                                    data-price="@item.PriceSnapshot"
                                    data-preview-kind="@item.PreviewKind"
                                    data-image-url="@(item.ImageUrl ?? string.Empty)"
                                    data-hex-code="@(item.HexCode ?? string.Empty)"
                                    data-asset-label="@item.AssetLabel">
                                    <td data-owned-product-cell="id">
                                        @item.Id
                                    </td>
                                    <td data-owned-product-cell="account">
                                        @item.UserAccount
                                    </td>
                                    <td>
                                        <div class="shop-product-thumb"
                                             data-owned-product-thumb>
                                            <span>@item.AssetLabel</span>
                                        </div>
                                    </td>
                                    <td data-owned-product-cell="name">
                                        @item.ProductName
                                    </td>
                                    <td data-owned-product-cell="type">
                                        <span class="owned-product-type-badge">
                                            @item.ProductType
                                        </span>
                                    </td>
                                    <td data-owned-product-cell="purchasedAt">
                                        @item.BoughtAtDisplay
                                    </td>
                                    <td data-owned-product-cell="price">
                                        @item.PriceSnapshot.ToString("N0")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="member-pagination-wrap">
                    <span class="member-page-info"
                          id="ownedProductPageInfo">
                        第 1 頁
                    </span>
                    <nav aria-label="持有商品表格分頁">
                        <ul class="pagination member-pagination"
                            id="ownedProductPagination"></ul>
                    </nav>
                </div>
            </div>
        </div>
    </section>
</div>

@section Styles {
    <link href="~/css/shop-management.css" rel="stylesheet" asp-append-version="true">
    <link href="~/css/owned-product-list.css" rel="stylesheet" asp-append-version="true">
}

@section Scripts {
    <script src="~/js/owned-product-list.js" asp-append-version="true"></script>
}
