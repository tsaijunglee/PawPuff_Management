@{
    ViewData["Title"] = "儀錶板";
    ViewData["CurrentScreen"] = "dashboard";
}

<div class="dashboard-content" id="dashboardScreen" data-screen-panel="dashboard">
    <section class="soft-panel attendance-panel attendance-dashboard-panel" aria-labelledby="attendanceTitle">
        <div class="attendance-layout">
            <div class="attendance-copy">
                <h2 class="section-title" id="attendanceTitle">
                    <span class="title-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
                    管理員打卡
                </h2>
                <div class="attendance-status">
                    <span class="status-pill" id="dashboardAttendanceStatus"><i class="bi bi-person-dash"></i>今日狀態：未打卡</span>
                    <span class="status-pill" id="dashboardClockInStatus"><i class="bi bi-clock"></i>上班 尚未打卡</span>
                    <span class="status-pill" id="dashboardClockOutStatus"><i class="bi bi-box-arrow-right"></i>下班 尚未打卡</span>
                </div>
            </div>

            <div class="attendance-actions">
                <a class="member-create-open-btn attendance-view-all-btn" href="./attendance-records.html">
                    <i class="bi bi-card-list me-1"></i>檢視所有打卡紀錄
                </a>
                <button class="attendance-btn" type="button" id="dashboardClockInBtn"><i class="bi bi-box-arrow-in-right"></i>打卡上班</button>
                <button class="attendance-btn" type="button" id="dashboardClockOutBtn"><i class="bi bi-box-arrow-right"></i>打卡下班</button>
            </div>
        </div>

        <div class="attendance-dashboard-table-view" aria-label="admin01 打卡紀錄">
            <div class="member-table-card">
                <div class="member-table-toolbar">
                    <strong><i class="bi bi-calendar-check me-2"></i>admin01 打卡紀錄表</strong>
                    <span class="member-count" id="dashboardAttendanceResultCount">共 0 筆</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover member-table attendance-table align-middle">
                        <thead>
                            <tr>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-dashboard-attendance-sort="date">日期 <i class="bi bi-sort-down"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-dashboard-attendance-sort="clockIn">上班時間 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-dashboard-attendance-sort="clockOut">下班時間 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                            </tr>
                        </thead>
                        <tbody id="dashboardAttendanceTableBody">
                            <tr data-dashboard-attendance-row data-date-key="2026-07-14" data-work-date="2026/7/14" data-clock-in="9:00" data-clock-out="18:10">
