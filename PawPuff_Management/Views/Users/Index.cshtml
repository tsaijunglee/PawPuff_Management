                        <tbody id="memberTableBody" data-table-columns="id,account,nickname,email">
                            @foreach (var item in Model)
                            {
                                <tr data-member-row
                                    data-id="@item.Id"
                                    data-account="@item.Account"
                                    data-password-hash="@item.PasswordHash"
                                    data-nickname="@item.Nickname"
                                    data-phone="@item.Phone"
                                    data-email="@item.Email"
                                    data-is-active="@item.IsActive.ToString().ToLower()"
                                    data-enabled="@item.IsActive.ToString().ToLower()"
                                    data-active_doll_configs_id="@item.ActiveDollConfigsId"
                                    data-active_doll_frame_id="@item.ActiveDollFrameId"
                                    data-point_balance="@item.PointBalance"
                                    data-created-at="@item.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")"
                                    data-admin-comment="@item.AdminComment"
                                    data-admin-updated-at="@(item.AdminUpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "")"
                                    data-modified-by-admin-id="@item.ModifiedByAdminId">
                                    <td data-member-cell="id">
                                        @item.Id
                                    </td>
                                    <td data-member-cell="account">
                                        @item.Account
                                    </td>

                                    <td data-member-cell="nickname">
                                        @item.Nickname
                                    </td>

                                    <td data-member-cell="phone">
                                        @item.Phone
                                    </td>

                                    <td data-member-cell="email">
                                        @item.Email
                                    </td>

                                    <td data-member-cell="points">
                                        @item.PointBalance.ToString("N0")
                                    </td>

                                    <td>
                                        <button class="member-detail-btn"
                                                type="button"
                                                data-member-detail="@item.Id">
                                            查看
                                            <i class="bi bi-chevron-right"></i>
                                        </button>
                                    </td>

                                    <td>
                                        <div class="form-check form-switch member-status-switch">
                                            <input class="form-check-input"
                                                   id="memberStatus@(item.Id)"
                                                   type="checkbox"
                                                   role="switch"
                                                   data-member-status="@item.Id"
                                                   checked="@item.IsActive">

                                            <label class="member-status-text"
                                                   for="memberStatus@(item.Id)">
                                                @(item.IsActive ? "啟用" : "停用")
                                            </label>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="member-pagination-wrap">
                    <span class="member-page-info" id="memberPageInfo">第 1 頁</span>
                    <nav aria-label="會員表格分頁">
                        <ul class="pagination member-pagination" id="memberPagination"></ul>
                    </nav>
                </div>
            </div>
        </div>

        <div class="member-detail-view d-none" id="memberDetailView">
            <div class="member-detail-card">
                <div class="member-detail-head">
                    <strong><i class="bi bi-person-vcard me-2"></i><span id="memberDetailTitle">會員詳情</span></strong>
                    <button class="member-back-btn px-3" id="memberDetailBack" type="button">
                        <i class="bi bi-arrow-left me-1"></i>返回會員管理
                    </button>
                </div>
                <div class="member-detail-grid" id="memberDetailGrid">
                    <div class="member-detail-field">
                        <div class="member-detail-label">編號</div>
                        <div class="member-detail-value" data-member-detail-value="id"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">帳號</div>
                        <div class="member-detail-value" data-member-detail-value="account"></div>
                    </div>
                    <div class="member-detail-field is-wide">
                        <div class="member-detail-label">密碼雜湊</div>
                        <div class="member-detail-value member-password-mask" data-member-detail-value="passwordMasked"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">暱稱</div>
                        <div class="member-detail-value" data-member-detail-value="nickname"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">信箱</div>
                        <div class="member-detail-value" data-member-detail-value="email"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">電話</div>
                        <div class="member-detail-value" data-member-detail-value="phone"></div>
                    </div>
                    <div class="member-detail-field is-wide">
                        <div class="member-detail-label">目前頭像</div>
                        <div class="member-avatar-preview" data-member-avatar-preview aria-label="目前頭像預覽">
                            <div class="member-avatar-layer" data-member-avatar-layer="doll"></div>
                            <div class="member-avatar-layer" data-member-avatar-layer="frame"></div>
                        </div>
                        <div class="member-avatar-meta">
                            <span>頭像編號：<span data-member-detail-value="activeDollConfigsId"></span></span>
                            <span>頭像框編號：<span data-member-detail-value="activeDollFrameId"></span></span>
                        </div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">點數</div>
                        <div class="member-detail-value" data-member-detail-value="pointsFormatted"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">帳號狀態</div>
                        <div class="form-check form-switch member-status-switch member-detail-status-switch">
                            <input class="form-check-input" id="memberDetailStatus" type="checkbox" role="switch">
                            <label class="member-status-text" id="memberDetailStatusLabel" for="memberDetailStatus">啟用</label>
                        </div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">註冊日期</div>
                        <div class="member-detail-value" data-member-detail-value="createdAt"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">帳號啟用/停用說明</div>
                        <div class="member-detail-value" data-member-detail-value="adminComment"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">啟用/停用變更日期</div>
                        <div class="member-detail-value" data-member-detail-value="adminUpdatedAt"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">操作啟用/停用管理員帳號</div>
                        <div class="member-detail-value" data-member-detail-value="modifiedByAdmin"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<div class="modal fade" id="memberCreateModal" tabindex="-1" aria-labelledby="memberCreateModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content member-form-modal">
            <form id="memberCreateForm" data-create-url="@Url.Action("Create", "Users")"  novalidate>

                 @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title" id="memberCreateModalTitle">新增會員資料</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="memberCreateAccount">帳號</label>
                            <input class="form-control" id="memberCreateAccount" type="text" autocomplete="off" required>
                            <div class="invalid-feedback">請輸入帳號。</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="memberCreatePassword">密碼</label>
                            <input class="form-control" id="memberCreatePassword" type="password" autocomplete="new-password" required>
                            <div class="invalid-feedback">請輸入密碼。</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="memberCreatePasswordConfirm">確認密碼</label>
                            <input class="form-control" id="memberCreatePasswordConfirm" type="password" autocomplete="new-password" required>
                            <div class="invalid-feedback">請再次輸入相同密碼。</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="memberCreateNickname">暱稱</label>
                            <input class="form-control" id="memberCreateNickname" type="text" autocomplete="off" required>
                            <div class="invalid-feedback">請輸入暱稱。</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="memberCreatePhone">電話</label>
                            <input class="form-control" id="memberCreatePhone" type="tel" autocomplete="tel" required>
                            <div class="invalid-feedback">請輸入電話。</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="memberCreateEmail">電子信箱</label>
                            <input class="form-control" id="memberCreateEmail" type="email" autocomplete="email" required>
                            <div class="invalid-feedback">請輸入有效的電子信箱。</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-warning fw-bold text-brown" id="memberCreateSubmit">新增會員</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="memberStatusModal" tabindex="-1" aria-labelledby="memberStatusModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content member-status-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="memberStatusModalTitle">啟用/停用說明</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <p class="member-status-modal-desc" id="memberStatusModalDescription">請輸入啟用/停用說明。</p>
                <label class="form-label fw-bold" for="memberStatusReason">啟用/停用說明</label>
                <textarea class="form-control" id="memberStatusReason" rows="4" placeholder="請輸入此次啟用/停用原因"></textarea>
                <div class="invalid-feedback d-none" id="memberStatusReasonError">請輸入啟用/停用說明後再確認。</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button"
                        class="btn btn-warning fw-bold text-brown"
                        id="memberStatusConfirm"
                        data-update-status-url="@Url.Action("UpdateStatus", "Users")">
                    確認切換
                </button>
            </div>
        </div>
    </div>
</div>