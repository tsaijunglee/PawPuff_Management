@model IEnumerable<PawPuff_Management.Models.DTOs.CreateUserDto>
@{
    ViewData["Title"] = "會員管理";
    ViewData["CurrentScreen"] = "member-management";
}

@Html.AntiForgeryToken()


<div class="dashboard-content management-screen" id="managementScreen" data-screen-panel="management">
    <section class="soft-panel management-panel">
        <span class="screen-kicker">
            <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            PawPuff Admin
        </span>
        <h2 class="screen-title" id="managementTitle">會員管理</h2>
        <p class="screen-desc" id="managementDescription">
            管理會員帳號與啟用狀態。
        </p>
        <div class="member-management-view" id="memberManagementView" data-screen="member-management" data-entity-type="member" data-detail-title="會員詳情" data-detail-description-template="查看「{nickname}」的會員完整資料、點數與帳號狀態。" data-create-success-message="已新增會員資料" data-actor-admin-account="admin01" data-actor-admin-id="1">
            <div class="member-page-actions">
                <button class="member-create-open-btn" id="memberCreateOpen" type="button" data-bs-toggle="modal" data-bs-target="#memberCreateModal">
                    <i class="bi bi-person-plus me-1"></i>新增會員資料
                </button>
            </div>
            <form class="member-search-panel" id="memberSearchForm">
                <div class="member-search-row">
                    <div class="member-search-field">
                        <label class="form-label" for="memberFilterId">編號</label>
                        <input class="form-control" id="memberFilterId" type="text" data-member-filter="id" placeholder="輸入編號">
                    </div>
                    <div class="member-search-field">
                        <label class="form-label" for="memberFilterAccount">帳號</label>
                        <input class="form-control" id="memberFilterAccount" type="text" data-member-filter="account" placeholder="輸入帳號">
                    </div>
                    <div class="member-search-field">
                        <label class="form-label" for="memberFilterNickname">暱稱</label>
                        <input class="form-control" id="memberFilterNickname" type="text" data-member-filter="nickname" placeholder="輸入暱稱">
                    </div>
                    <div class="member-search-field">
                        <label class="form-label" for="memberFilterPhone">電話</label>
                        <input class="form-control" id="memberFilterPhone" type="text" data-member-filter="phone" placeholder="輸入電話">
                    </div>
                    <div class="member-search-field is-wide">
                        <label class="form-label" for="memberFilterEmail">電子信箱</label>
                        <input class="form-control" id="memberFilterEmail" type="text" data-member-filter="email" placeholder="輸入電子信箱">
                    </div>
                    <div class="member-search-field">
                        <button class="member-reset-btn px-3" id="memberFilterReset" type="button">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>重設
                        </button>
                    </div>
                </div>
            </form>

            <div class="member-table-card">
                <div class="member-table-toolbar">
                    <strong><i class="bi bi-people me-2"></i>會員帳號資料表</strong>
                    <span class="member-count" id="memberResultCount">共 0 筆</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover member-table align-middle">
                        <thead>
                            <tr>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-member-sort="id">編號 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-member-sort="account">帳號 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-member-sort="nickname">暱稱 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-member-sort="phone">電話 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-member-sort="email">電子信箱 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-member-sort="points">點數 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <span class="sort-static-label">查看詳情</span>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-member-sort="enabled">停用/啟用 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                            </tr>
                        </thead>

