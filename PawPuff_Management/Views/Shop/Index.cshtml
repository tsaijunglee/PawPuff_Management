                                <td><div class="form-check form-switch member-status-switch shop-status-switch"><input class="form-check-input" id="shopStatus12" type="checkbox" role="switch" data-shop-status="12"><label class="member-status-text" for="shopStatus12">停用</label></div></td>
                            </tr> *@
                        </tbody>
                    </table>
                </div>
                <div class="member-pagination-wrap">
                    <span class="member-page-info" id="shopPageInfo">第 1 頁</span>
                    <nav aria-label="商城商品表格分頁">
                        <ul class="pagination member-pagination" id="shopPagination"></ul>
                    </nav>
                </div>
            </div>
        </div>

        <div class="member-detail-view d-none" id="shopDetailView">
            <div class="member-detail-card">
                <div class="member-detail-head">
                    <strong><i class="bi bi-box-seam me-2"></i><span id="shopDetailTitle">商品詳情</span></strong>
                    <button class="member-back-btn px-3" id="shopDetailBack" type="button">
                        <i class="bi bi-arrow-left me-1"></i>返回商城管理
                    </button>
                </div>
                <div class="shop-detail-visual" id="shopDetailVisual"></div>
                <div class="member-detail-grid shop-detail-grid" id="shopDetailGrid">
                    <div class="member-detail-field">
                        <div class="member-detail-label">編號</div>
                        <div class="member-detail-value" data-shop-detail-value="id"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">商品名稱</div>
                        <div class="member-detail-value" data-shop-detail-value="name"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">商品類型</div>
                        <div class="member-detail-value" data-shop-detail-value="type"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">價格</div>
                        <div class="shop-price-detail">
                            <div class="member-detail-value" data-shop-detail-value="priceFormatted"></div>
                            <button class="member-detail-btn" id="shopPriceEditOpen" type="button"><i class="bi bi-pencil-square"></i>修改價格</button>
                        </div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">停用/啟用</div>
                        <div class="form-check form-switch member-status-switch member-detail-status-switch">
                            <input class="form-check-input" id="shopDetailStatus" type="checkbox" role="switch">
                            <label class="member-status-text" id="shopDetailStatusLabel" for="shopDetailStatus">啟用</label>
                        </div>
                    </div>
                    <div class="member-detail-field" id="shopSortOrderField">
                        <div class="member-detail-label">圖層排序</div>
                        <select class="form-select shop-modal-select" id="shopDetailSortOrder">
                            <option value="1">1 最底層</option>
                            <option value="2">2</option>
                            <option value="3">3</option>
                            <option value="5">5</option>
                            <option value="6">6</option>
                            <option value="7">7 最上層</option>
                        </select>
                    </div>
                    <div class="member-detail-field" id="shopFrameShapeField">
                        <div class="member-detail-label">頭像框形狀</div>
                        <div class="member-detail-value" data-shop-detail-value="frameShape"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">管理員修改說明</div>
                        <div class="member-detail-value" data-shop-detail-value="adminComment"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">管理員更新日期</div>
                        <div class="member-detail-value" data-shop-detail-value="adminUpdatedAt"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">操作修改管理員帳號</div>
                        <div class="member-detail-value" data-shop-detail-value="modifiedByAdmin"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<div class="modal fade" id="shopCreateModal" tabindex="-1" aria-labelledby="shopCreateModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content member-form-modal">
            <form id="shopCreateForm" novalidate>
                <div class="modal-header">
                    <h5 class="modal-title" id="shopCreateModalTitle">新增商品</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="shopCreateName">商品名稱</label>
                            <input class="form-control" id="shopCreateName" type="text" autocomplete="off" required>
                            <div class="invalid-feedback">請輸入商品名稱。</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="shopCreatePrice">價格</label>
                            <input class="form-control" id="shopCreatePrice" type="number" min="0" step="1" required>
                            <div class="invalid-feedback">請輸入有效價格。</div>
                        </div>

                        <div class="col-12" data-shop-create-panel="底圖">
                            <label class="form-label fw-bold" for="shopCreateBodyImage">上傳圖片</label>
                            <input class="form-control" id="shopCreateBodyImage" type="file" accept="image/*" required>
                            <div class="invalid-feedback">請上傳一張圖片。</div>
                        </div>

                        <div class="col-12 col-md-6" data-shop-create-panel="配件">
                            <label class="form-label fw-bold" for="shopCreateAccessoryLineImage">上傳線稿圖片</label>
                            <input class="form-control" id="shopCreateAccessoryLineImage" type="file" accept="image/*" required>
                            <div class="invalid-feedback">請上傳一張線稿圖片。</div>
                        </div>
                        <div class="col-12 col-md-6" data-shop-create-panel="配件">
                            <label class="form-label fw-bold" for="shopCreateAccessoryMaskImage">上傳遮罩圖片</label>
                            <input class="form-control" id="shopCreateAccessoryMaskImage" type="file" accept="image/*" required>
                            <div class="invalid-feedback">請上傳一張遮罩圖片。</div>
                        </div>
                        <div class="col-12 col-md-6" data-shop-create-panel="配件">
                            <label class="form-label fw-bold" for="shopCreateAccessorySort">圖層排序</label>
                            <select class="form-select shop-modal-select" id="shopCreateAccessorySort" required>
                                <option value="">請選擇排序</option>
                                <option value="1">1 最底層</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                                <option value="5">5</option>
                                <option value="6">6</option>
                                <option value="7">7 最上層</option>
                            </select>
                            <div class="invalid-feedback">請選擇圖層排序。</div>
                        </div>

                        <div class="col-12 col-md-6" data-shop-create-panel="頭像框">
                            <label class="form-label fw-bold" for="shopCreateFrameImage">上傳圖片</label>
                            <input class="form-control" id="shopCreateFrameImage" type="file" accept="image/*" required>
                            <div class="invalid-feedback">請上傳一張圖片。</div>
                        </div>
                        <div class="col-12 col-md-6" data-shop-create-panel="頭像框">
                            <label class="form-label fw-bold d-block">框型</label>
                            <div class="shop-radio-row">
                                <label><input class="form-check-input" type="radio" name="shopCreateFrameShape" value="1" checked>方形</label>
                                <label><input class="form-check-input" type="radio" name="shopCreateFrameShape" value="0">圓形</label>
                            </div>
                        </div>

                        <div class="col-12 col-md-6" data-shop-create-panel="染劑">
                            <label class="form-label fw-bold" for="shopCreateColorPicker">顏色選擇</label>
                            <div class="shop-color-input-row">
                                <input class="form-control form-control-color" id="shopCreateColorPicker" type="color" value="#FF44AA" title="選擇染劑顏色">
                                <input class="form-control" id="shopCreateColorHex" type="text" value="#FF44AA" maxlength="7" placeholder="#RRGGBB" required>
                            </div>
                            <div class="invalid-feedback d-none" id="shopCreateColorError">請輸入有效色碼，例如 #FF44AA。</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-warning fw-bold text-brown" id="shopCreateSubmit">新增商品</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="shopStatusModal" tabindex="-1" aria-labelledby="shopStatusModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content member-status-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="shopStatusModalTitle">上下架說明</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <p class="member-status-modal-desc" id="shopStatusModalDescription">請輸入上下架說明。</p>
                <label class="form-label fw-bold" for="shopStatusReason">上下架說明</label>
                <textarea class="form-control" id="shopStatusReason" rows="4" placeholder="請輸入此次變更原因"></textarea>
                <div class="invalid-feedback d-none" id="shopStatusReasonError">請輸入說明後再確認。</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-warning fw-bold text-brown" id="shopStatusConfirm">確認切換</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="shopPriceModal" tabindex="-1" aria-labelledby="shopPriceModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content member-status-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="shopPriceModalTitle">修改商品價格</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <p class="member-status-modal-desc" id="shopPriceModalDescription">請輸入新價格與修改說明。</p>
                <label class="form-label fw-bold" for="shopPriceValue">新價格</label>
                <input class="form-control" id="shopPriceValue" type="number" min="0" step="1">
                <div class="invalid-feedback d-none" id="shopPriceValueError">請輸入有效價格。</div>
                <label class="form-label fw-bold mt-3" for="shopPriceReason">修改說明</label>
                <textarea class="form-control" id="shopPriceReason" rows="4" placeholder="請輸入此次修改原因"></textarea>
                <div class="invalid-feedback d-none" id="shopPriceReasonError">請輸入修改說明後再確認。</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-warning fw-bold text-brown" id="shopPriceConfirm">儲存價格</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/css/shop-management.css" rel="stylesheet" asp-append-version="true">
}

@section Scripts {
    <script src="~/js/shop-management.js" asp-append-version="true"></script>
}
