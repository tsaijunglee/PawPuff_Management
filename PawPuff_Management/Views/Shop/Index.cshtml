@model PawPuff_Management.Models.ViewModels.ShopIndexViewModel
@using System.Globalization
@{
    ViewData["Title"] = "商城管理";
    ViewData["CurrentScreen"] = "product-list";
}
@functions {
    // 將 null 或空字串統一輸出成 "NULL"，讓既有 JS normalizeNullable 可以沿用。
    string N(string? value) => string.IsNullOrWhiteSpace(value) ? "NULL" : value;

    // 將可為 null 的 Id 輸出成字串，沒有值時輸出 "NULL"。
    string N(int? value) => value?.ToString(CultureInfo.InvariantCulture) ?? "NULL";

    // 頭像框 IsSquare 給 JS 使用：
    // 1 = 方形，0 = 圓形，NULL = 非頭像框。
    string N(bool? value) => value is null ? "NULL" : value.Value ? "1" : "0";
}


<div class="dashboard-content management-screen" id="managementScreen" data-screen-panel="management">
    <section class="soft-panel management-panel">
        <span class="screen-kicker">
            <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            PawPuff Admin
        </span>
        <h2 class="screen-title" id="managementTitle">商城管理</h2>
        <p class="screen-desc" id="managementDescription">
            管理商城商品清單、上架狀態與新增商品素材。
        </p>
        <div class="screen-actions" id="shopManagementActions">
            <button class="member-create-open-btn" type="button" data-shop-create-open="底圖"><i class="bi bi-image me-1"></i>新增底圖</button>
            <button class="member-create-open-btn" type="button" data-shop-create-open="配件"><i class="bi bi-gem me-1"></i>新增配件</button>
            <button class="member-create-open-btn" type="button" data-shop-create-open="頭像框"><i class="bi bi-app-indicator me-1"></i>新增頭像框</button>
            <button class="member-create-open-btn" type="button" data-shop-create-open="染劑"><i class="bi bi-palette me-1"></i>新增染劑</button>
        </div>

        <div class="shop-management-view"
             id="shopManagementView"
             data-actor-admin-account="@Model.ActorAdminAccount"
             data-create-url="@Url.Action("Create", "Shop")"
             data-update-status-url="@Url.Action("UpdateStatus", "Shop")"
             data-update-price-url="@Url.Action("UpdatePrice", "Shop")"
             data-update-sort-url="@Url.Action("UpdateSortOrder", "Shop")">

            @* Ajax POST 會從這個 hidden input 讀取防偽 Token。 *@
            @Html.AntiForgeryToken()

            <form class="member-search-panel shop-search-panel" id="shopSearchForm">
                <div class="member-search-row shop-search-row">
                    <div class="member-search-field">
                        <label class="form-label" for="shopFilterId">編號</label>
                        <input class="form-control" id="shopFilterId" type="text" data-shop-filter="id" placeholder="輸入編號">
                    </div>
                    <div class="member-search-field is-wide">
                        <label class="form-label" for="shopFilterName">商品名</label>
                        <input class="form-control" id="shopFilterName" type="text" data-shop-filter="name" placeholder="輸入商品名">
                    </div>
                    <div class="member-search-field">
                        <label class="form-label" for="shopFilterType">商品類型</label>
                        <select class="form-select shop-filter-select" id="shopFilterType" data-shop-filter="type">
                            <option value="">全部</option>
                            <option value="底圖">底圖</option>
                            <option value="配件">配件</option>
                            <option value="頭像框">頭像框</option>
                            <option value="染劑">染劑</option>
                        </select>
                    </div>
                    <div class="member-search-field shop-price-range">
                        <label class="form-label" for="shopFilterPriceMin">價格區間</label>
                        <input class="form-control" id="shopFilterPriceMin" type="number" min="0" step="1" data-shop-filter="priceMin" placeholder="最小">
                        <span class="shop-range-separator">~</span>
                        <input class="form-control" id="shopFilterPriceMax" type="number" min="0" step="1" data-shop-filter="priceMax" placeholder="最大">
                    </div>
                    <div class="member-search-field">
                        <button class="member-reset-btn px-3" id="shopFilterReset" type="button">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>重設
                        </button>
                    </div>
                </div>
            </form>

            <div class="member-table-card">
                <div class="member-table-toolbar">
                    <strong><i class="bi bi-shop me-2"></i>商城商品資料表</strong>
                    <span class="member-count" id="shopResultCount">共 0 筆</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover member-table shop-table align-middle">
                        <thead>
                            <tr>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-shop-sort="id">編號 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col"><span class="sort-static-label">商品圖</span></th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-shop-sort="name">商品名稱 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-shop-sort="type">商品類型 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-shop-sort="price">價格 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                                <th scope="col"><span class="sort-static-label">查看詳情</span></th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-shop-sort="active">停用/啟用 <i class="bi bi-arrow-down-up"></i></button>
                                </th>
                            </tr>
                        </thead>
                        <tbody id="shopTableBody">
                            @foreach (var item in Model.Products)
                            {
                                // 染劑用色塊顯示；其他類型用圖片。
                                var colorClass = item.ProductType == "染劑" ? " is-color" : "";
                                var colorStyle = item.ProductType == "染劑" && !string.IsNullOrWhiteSpace(item.HexCode)
                                ? $"--shop-color:{item.HexCode}"
                                : "";

                                // 表格縮圖 fallback 文字。
                                // 底圖/頭像框顯示 ImageName；配件顯示 LineImageName；染劑顯示 HexCode。
                                var previewLabel = item.ProductType == "染劑" ? item.HexCode :
                                item.ProductType == "配件" ? item.LineImageName :
                                item.ImageName;

                                <tr data-shop-row
                                    data-id="@item.Id"
                                    data-product-type="@item.ProductType"
                                    data-body-id="@N(item.BodyId)"
                                    data-accessory-id="@N(item.AccessoryId)"
                                    data-frames-id="@N(item.FramesId)"
                                    data-colors-id="@N(item.ColorsId)"
                                    data-name="@item.Name"
                                    data-image-name="@N(item.ImageName)"
                                    data-image-src="@item.ImageSrc"
                                    data-line-image-name="@N(item.LineImageName)"
                                    data-line-image-src="@item.LineImageSrc"
                                    data-mask-image-name="@N(item.MaskImageName)"
                                    data-mask-image-src="@item.MaskImageSrc"
                                    data-sort-order="@N(item.SortOrder)"
                                    data-is-square="@N(item.IsSquare)"
                                    data-hex-code="@N(item.HexCode)"
                                    data-price="@item.Price"
                                    data-active="@item.IsActive.ToString().ToLowerInvariant()"
                                    data-admin-comment="@N(item.AdminComment)"
                                    data-admin-updated-at="@item.AdminUpdatedAtText"
                                    data-modified-by-admin="@N(item.ModifiedByAdminAccount)">
                                    <td data-shop-cell="id">@item.Id</td>
                                    <td>
                                        <div class="shop-product-thumb@colorClass" data-shop-thumb style="@colorStyle">
                                            <span>@N(previewLabel)</span>
                                        </div>
                                    </td>
                                    <td data-shop-cell="name">@item.Name</td>
                                    <td data-shop-cell="type">@item.ProductType</td>
                                    <td data-shop-cell="price">@item.PriceFormatted</td>
                                    <td>
                                        <button class="member-detail-btn" type="button" data-shop-detail="@item.Id">
                                            查看 <i class="bi bi-chevron-right"></i>
                                        </button>
                                    </td>
                                    <td>
                                        <div class="form-check form-switch member-status-switch shop-status-switch">
                                            <input class="form-check-input"
                                                   id="shopStatus@item.Id"
                                                   type="checkbox"
                                                   role="switch"
                                                   data-shop-status="@item.Id"
                                                   @(item.IsActive ? "checked" : "")>
                                            <label class="member-status-text" for="shopStatus@item.Id">@item.ActiveText</label>
                                        </div>
                                    </td>
                                </tr>
                            }
