@using PawPuff_Management.Models.ViewModels
@model CombinationPreviewViewModel

@{
    ViewData["Title"] = "組合預覽";
    ViewData["CurrentScreen"] = "combination-preview";

    var hasMissingOptions =
    Model.Bodies.Count == 0 ||
    Model.Colors.Count == 0 ||
    Model.Accessories.Count == 0;
}

<div class="dashboard-content management-screen" id="managementScreen" data-screen-panel="management">
    <section class="soft-panel management-panel">
        <span class="screen-kicker">
            <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            PawPuff Admin
        </span>
        <h2 class="screen-title" id="managementTitle">組合預覽</h2>
        <p class="screen-desc" id="managementDescription">
            選擇底圖、染劑及配件，預覽紙娃娃的搭配結果。
        </p>

        @if (hasMissingOptions)
        {
            <div class="combination-data-warning" role="status">
                資料庫中的底圖、染劑或配件沒有資料，
                部分下拉選單可能只有預設選項。
            </div>
        }

        <div class="combination-preview-view"
             id="combinationPreviewView"
             data-body-sort-order="@Model.BodySortOrder">
            <form class="combination-preview-form"
                  id="combinationPreviewForm"
                  autocomplete="off">
                <div class="combination-select-panel">
                    <div class="combination-field">
                        <label class="form-label"
                               for="previewBodySelect">
                            底圖
                        </label>

                        <select class="form-select combination-select"
                                id="previewBodySelect"
                                data-preview-item="body">
                            <option value="">請選擇底圖</option>

                            @foreach (var body in Model.Bodies)
                            {
                                <option value="@body.Id"
                                        data-name="@body.Name"
                                        data-image-name="@body.ImageName"
                                        data-image-url="@body.ImageUrl">
                                    @body.Name
                                </option>
                            }
                        </select>
                    </div>

                    <div class="combination-field">
                        <label class="form-label"
                               for="previewBodyColorSelect">
                            底圖染劑
                        </label>

                        <select class="form-select combination-select"
                                id="previewBodyColorSelect"
                                data-preview-color="body"
                                disabled>
                            <option value="">不套用染劑</option>

                            @foreach (var color in Model.Colors)
                            {
                                <option value="@color.Id"
                                        data-name="@color.Name"
                                        data-hex-code="@color.HexCode">
                                    @color.Name
                                </option>
                            }
                        </select>
                    </div>

                    @for (var slot = 1; slot <= 3; slot++)
                    {
                        var slotKey = $"accessory{slot}";
                        var accessorySelectId =
                        $"previewAccessory{slot}Select";
                        var colorSelectId =
                        $"previewAccessory{slot}ColorSelect";

                        <div class="combination-field">
                            <label class="form-label"
                                   for="@accessorySelectId">
                                配件 @slot
                            </label>

                            <select class="form-select combination-select"
                                    id="@accessorySelectId"
                                    data-preview-item="@slotKey">
                                <option value="">
                                    請選擇配件 @slot
                                </option>

                                @foreach (var accessory in Model.Accessories)
                                {
                                    <option value="@accessory.Id"
                                            data-name="@accessory.Name"
                                            data-line-name="@accessory.LineImageName"
                                            data-line-url="@accessory.LineImageUrl"
                                            data-mask-name="@accessory.MaskImageName"
                                            data-mask-url="@accessory.MaskImageUrl"
                                            data-sort-order="@accessory.SortOrder">
                                        @accessory.Name
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="combination-field">
                            <label class="form-label"
                                   for="@colorSelectId">
                                配件 @slot 染劑
                            </label>

                            <select class="form-select combination-select"
                                    id="@colorSelectId"
                                    data-preview-color="@slotKey"
                                    disabled>
                                <option value="">不套用染劑</option>

                                @foreach (var color in Model.Colors)
                                {
                                    <option value="@color.Id"
                                            data-name="@color.Name"
                                            data-hex-code="@color.HexCode">
                                        @color.Name
                                    </option>
                                }
                            </select>
                        </div>
                    }
                </div>

                <div class="combination-preview-panel" aria-live="polite">
                    <div class="combination-preview-frame"
                         id="combinationPreviewFrame"
                         role="img"
                         aria-label="紙娃娃組合預覽">
                        <div class="combination-preview-empty"
                             id="combinationPreviewEmpty">
                            請先選擇底圖或配件
                        </div>

                        <canvas class="combination-preview-canvas d-none"
                                id="combinationPreviewCanvas"
                                aria-hidden="true">
                        </canvas>

                        <div class="combination-preview-error d-none"
                             id="combinationPreviewError"
                             role="alert">
                        </div>
                    </div>

                    <div class="combination-layer-list"
                         id="combinationLayerList">
                    </div>
                </div>
            </form>
        </div>
    </section>
</div>

@section Styles {
    <link href="~/css/combination-preview.css"
          rel="stylesheet"
          asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/combination-preview.js"
            asp-append-version="true"></script>
}
