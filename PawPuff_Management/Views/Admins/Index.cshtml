<div class="modal fade" id="memberCreateModal" tabindex="-1" aria-labelledby="memberCreateModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content member-form-modal">
            <form id="memberCreateForm" novalidate>
                <div class="modal-header">
                    <h5 class="modal-title" id="memberCreateModalTitle">新增管理員資料</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="memberCreateAccount">帳號</label>
                            <input class="form-control" id="memberCreateAccount" type="text" autocomplete="off" required>
                            <div class="invalid-feedback">請輸入帳號。</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="memberCreatePassword">密碼</label>
                            <input class="form-control" id="memberCreatePassword" type="password" autocomplete="new-password" required>
                            <div class="invalid-feedback">請輸入密碼。</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="memberCreatePasswordConfirm">確認密碼</label>
                            <input class="form-control" id="memberCreatePasswordConfirm" type="password" autocomplete="new-password" required>
                            <div class="invalid-feedback">請再次輸入相同密碼。</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="memberCreateNickname">暱稱</label>
                            <input class="form-control" id="memberCreateNickname" type="text" autocomplete="off" required>
                            <div class="invalid-feedback">請輸入暱稱。</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold" for="memberCreateEmail">電子信箱</label>
                            <input class="form-control" id="memberCreateEmail" type="email" autocomplete="email" required>
                            <div class="invalid-feedback">請輸入有效的電子信箱。</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-warning fw-bold text-brown" id="memberCreateSubmit">新增管理員</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="memberStatusModal" tabindex="-1" aria-labelledby="memberStatusModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content member-status-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="memberStatusModalTitle">啟用/停用說明</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <p class="member-status-modal-desc" id="memberStatusModalDescription">請輸入啟用/停用說明。</p>
                <label class="form-label fw-bold" for="memberStatusReason">啟用/停用說明</label>
                <textarea class="form-control" id="memberStatusReason" rows="4" placeholder="請輸入此次啟用/停用原因"></textarea>
                <div class="invalid-feedback d-none" id="memberStatusReasonError">請輸入啟用/停用說明後再確認。</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-warning fw-bold text-brown" id="memberStatusConfirm">確認切換</button>
            </div>
        </div>
    </div>
</div>

