@model PawPuff_Management.Models.ViewModels.PointsIndexViewModel

@{
    ViewData["Title"] = "點數管理";
    ViewData["CurrentScreen"] = "point-management";
}

<div class="dashboard-content management-screen" id="managementScreen" data-screen-panel="management">
    <section class="soft-panel management-panel">
        <span class="screen-kicker">
            <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            PawPuff Admin
        </span>
        <h2 class="screen-title" id="managementTitle">點數管理</h2>
        <p class="screen-desc" id="managementDescription">
            查詢與管理會員點數紀錄，並支援必要調整。
        </p>

        <div class="point-management-view" id="pointManagementView">
            <div class="member-page-actions point-page-actions">
                <button class="member-create-open-btn"
                        id="pointCreateOpen"
                        type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#pointCreateModal">
                    <i class="bi bi-plus-circle me-1"></i>新增點數變更
                </button>
            </div>

            <form class="member-search-panel point-search-panel"
                  id="pointSearchForm">
                <div class="member-search-row point-search-row">
                    <div class="member-search-field">
                        <label class="form-label" for="pointFilterAccount">
                            帳號
                        </label>
                        <input class="form-control"
                               id="pointFilterAccount"
                               type="text"
                               data-point-filter="account"
                               placeholder="輸入帳號">
                    </div>

                    <div class="member-search-field">
                        <label class="form-label" for="pointFilterRule">
                            規則名稱
                        </label>
                        <select class="form-select point-filter-select"
                                id="pointFilterRule"
                                data-point-filter="rule">
                            <option value="">全部</option>
                            @foreach (var changeType in Model.ChangeTypes)
                            {
                                <option value="@changeType.ActionName">
                                    @changeType.ActionName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="member-search-field point-date-range">
                        <label class="form-label" for="pointFilterDateStart">
                            日期起/訖
                        </label>
                        <input class="form-control"
                               id="pointFilterDateStart"
                               type="date"
                               data-point-filter="dateStart">
                        <span class="point-range-separator">~</span>
                        <input class="form-control"
                               id="pointFilterDateEnd"
                               type="date"
                               data-point-filter="dateEnd">
                    </div>

                    <div class="member-search-field">
                        <button class="member-reset-btn px-3"
                                id="pointFilterReset"
                                type="button">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>重設
                        </button>
                    </div>
                </div>
            </form>

            <div class="member-table-card">
                <div class="member-table-toolbar">
                    <strong>
                        <i class="bi bi-plus-slash-minus me-2"></i>點數異動資料表
                    </strong>
                    <span class="member-count" id="pointResultCount">
                        共 @Model.TotalCount 筆
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover member-table point-table align-middle">
                        <thead>
                            <tr>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-point-sort="account">
                                        帳號 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-point-sort="rule">
                                        規則名稱 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-point-sort="change">
                                        點數變化 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-point-sort="balance">
                                        變更後點數餘額 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-point-sort="description">
                                        描述 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-point-sort="changedAt">
                                        變更時間 <i class="bi bi-sort-down"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-point-sort="admin">
                                        操作管理員帳號 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                                <th scope="col">
                                    <button class="sort-btn" type="button" data-point-sort="order">
                                        對應訂單編號 <i class="bi bi-arrow-down-up"></i>
                                    </button>
                                </th>
                            </tr>
                        </thead>

                        <tbody id="pointTableBody">
                            @foreach (var item in Model.Transactions)
                            {
                                var adminValue = item.ModifiedByAdminAccount ?? "NULL";
                                var orderValue = item.UserProductId?.ToString() ?? "NULL";
                                var changeClass = item.PointChange > 0
                                ? "is-positive"
                                : item.PointChange < 0
                                ? "is-negative"
                                : "is-zero";
                                var changeText = item.PointChange > 0
                                ? $"+{item.PointChange:N0}"
                                : item.PointChange.ToString("N0");

                                <tr data-point-row
                                    data-id="@item.Id"
                                    data-account="@item.UserAccount"
                                    data-rule="@item.ActionName"
                                    data-change="@item.PointChange"
                                    data-balance="@item.BalanceAfter"
                                    data-description="@item.Description"
                                    data-changed-at="@item.CreatedAtDisplay"
                                    data-admin="@adminValue"
                                    data-order="@orderValue">
                                    <td data-point-cell="account">@item.UserAccount</td>
                                    <td data-point-cell="rule">@item.ActionName</td>
                                    <td data-point-cell="change">
                                        <span class="point-change @changeClass">@changeText</span>
                                    </td>
                                    <td data-point-cell="balance">@item.BalanceAfter.ToString("N0")</td>
                                    <td data-point-cell="description">@item.Description</td>
                                    <td data-point-cell="changedAt">@item.CreatedAtDisplay</td>
                                    <td data-point-cell="admin">
                                        @if (item.ModifiedByAdminAccount is null)
                                        {
                                            <span class="point-null" aria-label="NULL">—</span>
                                        }
                                        else
                                        {
                                            @item.ModifiedByAdminAccount
                                        }
                                    </td>
                                    <td data-point-cell="order">
                                        @if (item.UserProductId is null)
                                        {
                                            <span class="point-null" aria-label="NULL">—</span>
                                        }
                                        else
                                        {
                                            @item.UserProductId
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="member-pagination-wrap">
                    <span class="member-page-info" id="pointPageInfo">第 1 頁</span>
                    <nav aria-label="點數異動表格分頁">
                        <ul class="pagination member-pagination" id="pointPagination"></ul>
                    </nav>
                </div>
            </div>
        </div>
    </section>
</div>

<div class="modal fade"
     id="pointCreateModal"
     tabindex="-1"
     aria-labelledby="pointCreateModalTitle"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content member-form-modal">
            <form id="pointCreateForm"
                  data-create-url="@Url.Action("Create", "Points")"
                  novalidate>
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title" id="pointCreateModalTitle">
                        新增點數變更
                    </h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="關閉"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label" for="pointCreateAccount">
                            帳號
                        </label>
                        <input class="form-control point-modal-input"
                               id="pointCreateAccount"
                               type="text"
                               list="pointAccountOptions"
                               maxlength="50"
                               autocomplete="off"
                               placeholder="輸入或選擇會員帳號"
                               required>
                        <datalist id="pointAccountOptions">
                            @foreach (var userAccount in Model.UserAccounts)
                            {
                                var balanceLabel =
                                $"目前點數 {userAccount.PointBalance:N0}";

                                <option value="@userAccount.Account"
                                        label="@balanceLabel"></option>
                            }
                        </datalist>
                        <div class="form-text">
                            可直接輸入文字，或從 User 資料表的帳號選項中選擇。
                        </div>
                        <div class="invalid-feedback">請輸入會員帳號。</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="pointCreateChange">
                            點數變化
                        </label>
                        <input class="form-control point-modal-input"
                               id="pointCreateChange"
                               type="number"
                               step="1"
                               placeholder="輸入正數或負數，例如 100 或 -100"
                               required>
                        <div class="invalid-feedback">
                            請輸入不可為 0 的整數點數變化。
                        </div>
                    </div>

                    <div>
                        <label class="form-label" for="pointCreateDescription">
                            描述
                        </label>
                        <textarea class="form-control point-modal-textarea"
                                  id="pointCreateDescription"
                                  rows="4"
                                  maxlength="100"
                                  placeholder="輸入本次點數變更說明"
                                  required></textarea>
                        <div class="invalid-feedback">
                            請輸入 100 個字以內的描述。
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        取消
                    </button>
                    <button type="submit"
                            class="btn btn-warning fw-bold text-brown"
                            id="pointCreateSubmit">
                        新增變更
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/css/point-management.css" rel="stylesheet" asp-append-version="true">
}

@section Scripts {
    <script src="~/js/point-management.js" asp-append-version="true"></script>
}
