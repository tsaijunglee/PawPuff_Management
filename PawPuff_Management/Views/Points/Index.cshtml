<div class="modal fade" id="pointCreateModal" tabindex="-1" aria-labelledby="pointCreateModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content member-form-modal">
            <form id="pointCreateForm" novalidate>
                <div class="modal-header">
                    <h5 class="modal-title" id="pointCreateModalTitle">新增點數變更</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label" for="pointCreateAccount">帳號</label>
                        <input class="form-control point-modal-input" id="pointCreateAccount" type="text" list="pointAccountOptions" placeholder="輸入帳號" autocomplete="off" required>
                        <datalist id="pointAccountOptions">
                            <option value="sunny01" data-balance="50">目前點數 50</option>
                            <option value="milktea02" data-balance="850">目前點數 850</option>
                            <option value="pudding03" data-balance="50">目前點數 50</option>
                            <option value="afu04" data-balance="650">目前點數 650</option>
                            <option value="cocoa05" data-balance="50">目前點數 50</option>
                            <option value="millet06" data-balance="550">目前點數 550</option>
                            <option value="xiaobai07" data-balance="900">目前點數 900</option>
                            <option value="tofu08" data-balance="400">目前點數 400</option>
                            <option value="happy09" data-balance="0">目前點數 0</option>
                            <option value="anan10" data-balance="1000">目前點數 1000</option>
                            <option value="yuzu11" data-balance="300">目前點數 300</option>
                            <option value="mochi12" data-balance="350">目前點數 350</option>
                        </datalist>
                        <div class="invalid-feedback">請選擇假資料中存在的帳號。</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="pointCreateChange">點數變化</label>
                        <input class="form-control point-modal-input" id="pointCreateChange" type="number" step="1" placeholder="輸入正數或負數，例如 100 或 -100" required>
                        <div class="invalid-feedback">請輸入不可為 0 的點數變化。</div>
                    </div>
                    <div>
                        <label class="form-label" for="pointCreateDescription">描述</label>
                        <textarea class="form-control point-modal-textarea" id="pointCreateDescription" rows="4" placeholder="輸入本次點數變更說明" required></textarea>
                        <div class="invalid-feedback">請輸入描述。</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-warning fw-bold text-brown">新增變更</button>
                </div>
            </form>
        </div>
    </div>
</div>

