        <span class="screen-kicker">
            <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            PawPuff Admin
        </span>
        <h2 class="screen-title" id="managementTitle">點數管理</h2>
        <p class="screen-desc" id="managementDescription">
            查詢與管理會員點數紀錄，並支援必要調整。
        </p>
        <div class="point-management-view" id="pointManagementView" data-actor-admin-account="admin01">
            <div class="member-page-actions point-page-actions">
                <button class="member-create-open-btn" id="pointCreateOpen" type="button" data-bs-toggle="modal" data-bs-target="#pointCreateModal">
                    <i class="bi bi-plus-circle me-1"></i>新增點數變更
                </button>
            </div>

            <form class="member-search-panel point-search-panel" id="pointSearchForm">
                <div class="member-search-row point-search-row">
                    <div class="member-search-field">
                        <label class="form-label" for="pointFilterAccount">帳號</label>
                        <input class="form-control" id="pointFilterAccount" type="text" data-point-filter="account" placeholder="輸入帳號">
                    </div>
                    <div class="member-search-field">
                        <label class="form-label" for="pointFilterRule">規則名稱</label>
                        <select class="form-select point-filter-select" id="pointFilterRule" data-point-filter="rule">
                            <option value="">全部</option>
                            <option value="每日登入打卡">每日登入打卡</option>
                            <option value="每日發文">每日發文</option>
                            <option value="每日回文">每日回文</option>
                            <option value="每日點讚">每日點讚</option>
                            <option value="發文收到讚">發文收到讚</option>
                            <option value="發文被收藏">發文被收藏</option>
                            <option value="贊助平台">贊助平台</option>
                            <option value="管理員給予">管理員給予</option>
                            <option value="管理員扣除">管理員扣除</option>
                            <option value="商城消費">商城消費</option>
                        </select>
                    </div>
                    <div class="member-search-field point-date-range">
                        <label class="form-label" for="pointFilterDateStart">日期起/訖</label>
                        <input class="form-control" id="pointFilterDateStart" type="date" data-point-filter="dateStart">
                        <span class="point-range-separator">~</span>
                        <input class="form-control" id="pointFilterDateEnd" type="date" data-point-filter="dateEnd">
                    </div>
                    <div class="member-search-field">
                        <button class="member-reset-btn px-3" id="pointFilterReset" type="button">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>重設
                        </button>
                    </div>
                </div>
            </form>

