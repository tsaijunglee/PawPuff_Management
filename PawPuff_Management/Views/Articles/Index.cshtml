@model PawPuff_Management.ViewModels.Article.ArticleIndexVm
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var r2Base = (Configuration["CloudflareR2:PublicUrl"] ?? "").TrimEnd('/');
}
@{
    ViewData["Title"] = "文章管理";
    ViewData["CurrentScreen"] = "article-management";
}

<div class="dashboard-content management-screen" id="managementScreen" data-screen-panel="management">
    <section class="soft-panel management-panel">
        <span class="screen-kicker">
            <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            PawPuff Admin
        </span>
        <h2 class="screen-title" id="managementTitle">文章管理</h2>
        <p class="screen-desc" id="managementDescription">
            檢視、建立、編輯與上下架文章內容。
        </p>

        <div class="article-management-view" id="articleManagementView">
            <div class="member-page-actions">
                <button class="member-create-open-btn" id="articleCreateOpen" type="button" data-bs-toggle="modal" data-bs-target="#articleCreateModal">
                    <i class="bi bi-file-earmark-plus me-1"></i>新增文章
                </button>
            </div>

            <form class="member-search-panel" id="articleSearchForm">
                <div class="member-search-row article-search-row">
                    <div class="member-search-field">
                        <label class="form-label" for="articleFilterId">編號</label>
                        <input class="form-control" id="articleFilterId" type="text" data-article-filter="id" placeholder="輸入編號">
                    </div>
                    <div class="member-search-field">
                        <label class="form-label" for="articleFilterAccount">發文者帳號</label>
                        <input class="form-control" id="articleFilterAccount" type="text" data-article-filter="account" placeholder="輸入帳號">
                    </div>
                    <div class="member-search-field is-wide">
                        <label class="form-label" for="articleFilterCategory">文章分類</label>
                        <select class="form-select" id="articleFilterCategory" data-article-filter="category">
                            <option value="">全部分類</option>
                            @foreach (var c in Model.Categories)
                            {
                                <option value="@c.Name">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="member-search-field is-wide">
                        <label class="form-label" for="articleFilterTitle">文章標題</label>
                        <input class="form-control" id="articleFilterTitle" type="text" data-article-filter="title" placeholder="輸入文章標題">
                    </div>
                    <div class="member-search-field">
                        <button class="member-reset-btn px-3" id="articleFilterReset" type="button">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>重設
                        </button>
                    </div>
                </div>
            </form>

            <div class="member-table-card article-table-card">
                <div class="member-table-toolbar">
                    <strong><i class="bi bi-file-earmark-text me-2"></i>文章資料表</strong>
                    <span class="member-count" id="articleResultCount">共 0 筆</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover member-table article-table align-middle">
                        <thead>
                            <tr>
                                <th scope="col"><button class="sort-btn" type="button" data-article-sort="id">編號 <i class="bi bi-arrow-down-up"></i></button></th>
                                <th scope="col"><button class="sort-btn" type="button" data-article-sort="account">發文者帳號 <i class="bi bi-arrow-down-up"></i></button></th>
                                <th scope="col"><button class="sort-btn" type="button" data-article-sort="category">文章分類 <i class="bi bi-arrow-down-up"></i></button></th>
                                <th scope="col"><button class="sort-btn" type="button" data-article-sort="title">文章標題 <i class="bi bi-arrow-down-up"></i></button></th>
                                <th scope="col"><span class="sort-static-label">查看詳情</span></th>
                                <th scope="col"><button class="sort-btn" type="button" data-article-sort="active">停用/啟用 <i class="bi bi-arrow-down-up"></i></button></th>
                            </tr>
                        </thead>
                        <tbody id="articleTableBody">
                            @foreach (var a in Model.Articles)
                            {
                                var imageNames = string.Join("|", a.ImageNames);
                                var imageSrcs = string.Join("|", a.ImageNames.Select(n => $"{r2Base}/articles/{n}"));
                                <tr data-article-row data-id="@a.Id"
                                    data-account="@a.AuthorAccount"
                                    data-category-name="@a.CategoryName"
                                    data-title="@a.Title"
                                    data-article-content="@a.ArticleContent"
                                    data-image-names="@imageNames"
                                    data-image-srcs="@imageSrcs"
                                    data-active="@a.IsActive.ToString().ToLower()"
                                    data-created-at="@(a.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss"))"
                                    data-updated-at="@(a.UpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "NULL")"
                                    data-admin-comment="@(a.AdminComment ?? "NULL")"
                                    data-admin-updated-at="@(a.AdminUpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "NULL")"
                                    data-modified-by-admin="@(a.ModifiedByAdminAccount ?? "NULL")">
                                    <td data-article-cell="id">@a.Id</td>
                                    <td data-article-cell="account">@a.AuthorAccount</td>
                                    <td data-article-cell="category">@a.CategoryName</td>
                                    <td data-article-cell="title">@a.Title</td>
                                    <td><button class="member-detail-btn" type="button" data-article-detail="@a.Id">查看 <i class="bi bi-chevron-right"></i></button></td>
                                    <td>
                                        <div class="form-check form-switch member-status-switch article-status-switch">
                                            <input class="form-check-input" id="articleStatus@(a.Id)" type="checkbox" role="switch" data-article-status="@a.Id" checked="@(a.IsActive ? "checked" : null)">
                                            <label class="member-status-text" for="articleStatus@(a.Id)">@(a.IsActive ? "啟用" : "停用")</label>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="member-pagination-wrap">
                    <span class="member-page-info" id="articlePageInfo">第 1 頁</span>
                    <nav aria-label="文章表格分頁">
                        <ul class="pagination member-pagination" id="articlePagination"></ul>
                    </nav>
                </div>
            </div>
        </div>

        <div class="member-detail-view d-none" id="articleDetailView">
            <div class="member-detail-card">
                <div class="member-detail-head">
                    <strong><i class="bi bi-file-earmark-text me-2"></i><span id="articleDetailTitle">文章詳情</span></strong>
                    <button class="member-back-btn px-3" id="articleDetailBack" type="button">
                        <i class="bi bi-arrow-left me-1"></i>返回文章管理
                    </button>
                </div>
                <div class="article-engagement-actions">
                    <button class="article-engagement-btn d-none" id="articleEditOpen" type="button">
                        <i class="bi bi-pencil-square me-1"></i>編輯文章
                    </button>
                    <button class="article-engagement-btn" id="articleLikeOpen" type="button" data-reaction-open="like">
                        <i class="bi bi-hand-thumbs-up me-1"></i>檢視按讚 <span id="articleLikeCount">0</span>
                    </button>
                    <button class="article-engagement-btn" id="articleFavoriteOpen" type="button" data-reaction-open="favorite">
                        <i class="bi bi-bookmark-heart me-1"></i>檢視收藏 <span id="articleFavoriteCount">0</span>
                    </button>
                </div>
                <div class="member-detail-grid article-detail-grid" id="articleDetailGrid">
                    <div class="member-detail-field">
                        <div class="member-detail-label">編號</div>
                        <div class="member-detail-value" data-article-detail-value="id"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">發文者帳號</div>
                        <div class="member-detail-value" data-article-detail-value="account"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">文章分類</div>
                        <div class="member-detail-value" data-article-detail-value="categoryName"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">停用/啟用</div>
                        <div class="form-check form-switch member-status-switch article-status-switch article-detail-status-switch">
                            <input class="form-check-input" id="articleDetailStatus" type="checkbox" role="switch">
                            <label class="member-status-text" id="articleDetailStatusLabel" for="articleDetailStatus">啟用</label>
                        </div>
                    </div>
                    <div class="member-detail-field is-wide">
                        <div class="member-detail-label">文章標題</div>
                        <div class="member-detail-value" data-article-detail-value="title"></div>
                    </div>
                    <div class="member-detail-field is-wide">
                        <div class="member-detail-label">文章內容</div>
                        <div class="member-detail-value article-content-value" data-article-detail-value="articleContent"></div>
                    </div>
                    <div class="member-detail-field is-wide article-images-field">
                        <div class="member-detail-label">文章附圖</div>
                        <div class="article-image-viewer is-empty" id="articleImageViewer">
                            <button class="article-image-nav" id="articleImagePrev" type="button" aria-label="上一張附圖">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <div class="article-image-frame">
                                <img class="article-detail-image" id="articleDetailImage" alt="文章附圖">
                                <div class="article-image-fallback" id="articleImageFallback"></div>
                            </div>
                            <button class="article-image-nav" id="articleImageNext" type="button" aria-label="下一張附圖">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                        <div class="article-image-meta" id="articleImageMeta"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">文章建立時間</div>
                        <div class="member-detail-value" data-article-detail-value="createdAt"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">作者更新文章時間</div>
                        <div class="member-detail-value" data-article-detail-value="updatedAt"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">文章屏蔽說明</div>
                        <div class="member-detail-value" data-article-detail-value="adminComment"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">文章屏蔽日期</div>
                        <div class="member-detail-value" data-article-detail-value="adminUpdatedAt"></div>
                    </div>
                    <div class="member-detail-field">
                        <div class="member-detail-label">操作屏蔽管理員帳號</div>
                        <div class="member-detail-value" data-article-detail-value="modifiedByAdmin"></div>
                    </div>
                </div>
                <div class="article-comments-panel">
                    <div class="article-comments-head">
                        <strong><i class="bi bi-chat-dots me-2"></i>留言一覽</strong>
                        <span class="member-count" id="articleCommentCount">共 0 則</span>
                    </div>
                    <div class="article-comment-list" id="articleCommentList"></div>
                </div>
            </div>
        </div>
    </section>
</div>

<div class="d-none" id="articleReactionData" aria-hidden="true">
    @foreach (var r in Model.Reactions)
    {
        <span data-article-reaction="@r.Type" data-article-id="@r.ArticleId" data-account="@r.Account" data-created-at="@(r.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss"))"></span>
    }
</div>

<div class="d-none" id="articleCommentData" aria-hidden="true">
    @foreach (var c in Model.CommentRows)
    {
        <span data-article-comment
              data-comment-id="@c.Id"
              data-article-id="@c.ArticleId"
              data-parent-comment-id="@(c.ParentCommentId?.ToString() ?? "NULL")"
              data-account="@c.Account"
              data-comment-content="@c.CommentContent"
              data-active="@c.IsActive.ToString().ToLower()"
              data-created-at="@(c.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss"))"
              data-updated-at="@(c.UpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "NULL")"
              data-admin-comment="@(c.AdminComment ?? "NULL")"
              data-admin-updated-at="@(c.AdminUpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "NULL")"
              data-modified-by-admin="@(c.ModifiedByAdminAccount ?? "NULL")"></span>
    }
</div>

<div class="modal fade" id="articleCreateModal" tabindex="-1" aria-labelledby="articleCreateModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content member-form-modal">
            <form id="articleCreateForm" novalidate>
                <div class="modal-header">
                    <h5 class="modal-title" id="articleCreateModalTitle">新增文章</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="articleCreateCategory">文章分類</label>
                            <select class="form-select" id="articleCreateCategory" required>
                                <option value="">請選擇分類</option>
                                @foreach (var c in Model.Categories)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </select>
                            <div class="invalid-feedback">請選擇文章分類。</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold" for="articleCreateTitle">文章標題</label>
                            <input class="form-control" id="articleCreateTitle" type="text" autocomplete="off" required>
                            <div class="invalid-feedback">請輸入文章標題。</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold" for="articleCreateContent">文章內容</label>
                            <textarea class="form-control" id="articleCreateContent" rows="5" required></textarea>
                            <div class="invalid-feedback">請輸入文章內容。</div>
                        </div>
                        <div class="col-12">
                            <div class="article-upload-control">
                                <label class="article-upload-button" for="articleCreateImages">
                                    <i class="bi bi-images me-1"></i>上傳圖片
                                </label>
                                <input class="article-upload-input" id="articleCreateImages" type="file" accept="image/*" multiple>
                                <span class="article-upload-hint">可不傳，也可選擇多張圖片後調整順序。</span>
                            </div>
                            <div class="article-image-preview-list" id="articleImagePreviewList" aria-label="已選擇圖片預覽"></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-warning fw-bold text-brown">新增文章</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="articleEditModal" tabindex="-1" aria-labelledby="articleEditModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content member-form-modal">
            <form id="articleEditForm" novalidate>
                <div class="modal-header">
                    <h5 class="modal-title" id="articleEditModalTitle">編輯文章</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold" for="articleEditCategory">文章分類</label>
                            <select class="form-select" id="articleEditCategory" required>
                                <option value="">請選擇分類</option>
                                @foreach (var c in Model.Categories)
                                {
                                    <option value="@c.Name">@c.Name</option>
                                }
                            </select>
                            <div class="invalid-feedback">請選擇文章分類。</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold" for="articleEditTitle">文章標題</label>
                            <input class="form-control" id="articleEditTitle" type="text" autocomplete="off" required>
                            <div class="invalid-feedback">請輸入文章標題。</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold" for="articleEditContent">文章內容</label>
                            <textarea class="form-control" id="articleEditContent" rows="5" required></textarea>
                            <div class="invalid-feedback">請輸入文章內容。</div>
                        </div>
                        <div class="col-12">
                            <div class="article-upload-control">
                                <label class="article-upload-button" for="articleEditImages">
                                    <i class="bi bi-images me-1"></i>加入圖片
                                </label>
                                <input class="article-upload-input" id="articleEditImages" type="file" accept="image/*" multiple>
                                <span class="article-upload-hint">可調整順序、移除既有圖片，或加入多張新圖片。</span>
                            </div>
                            <div class="article-image-preview-list" id="articleEditImagePreviewList" aria-label="文章圖片預覽與排序"></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-warning fw-bold text-brown">儲存修改</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="articleStatusModal" tabindex="-1" aria-labelledby="articleStatusModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content member-status-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="articleStatusModalTitle">變更文章狀態</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <p class="member-status-modal-desc" id="articleStatusModalDescription">請輸入文章屏蔽說明。</p>
                <label class="form-label fw-bold" for="articleStatusReason">文章屏蔽/解除屏蔽說明</label>
                <textarea class="form-control" id="articleStatusReason" rows="4" placeholder="請輸入此次變更原因"></textarea>
                <div class="invalid-feedback d-none" id="articleStatusReasonError">請輸入說明後再確認。</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-warning fw-bold text-brown" id="articleStatusConfirm">確認切換</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="commentStatusModal" tabindex="-1" aria-labelledby="commentStatusModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content member-status-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="commentStatusModalTitle">變更留言狀態</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <p class="member-status-modal-desc" id="commentStatusModalDescription">請輸入留言屏蔽說明。</p>
                <label class="form-label fw-bold" for="commentStatusReason">留言屏蔽/解除屏蔽說明</label>
                <textarea class="form-control" id="commentStatusReason" rows="4" placeholder="請輸入此次變更原因"></textarea>
                <div class="invalid-feedback d-none" id="commentStatusReasonError">請輸入說明後再確認。</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-warning fw-bold text-brown" id="commentStatusConfirm">確認切換</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="articleReactionModal" tabindex="-1" aria-labelledby="articleReactionModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content member-form-modal">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="articleReactionModalTitle">檢視按讚</h5>
                    <div class="article-reaction-count" id="articleReactionModalCount">共 0 筆</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table table-hover member-table article-reaction-table align-middle">
                        <thead>
                            <tr>
                                <th scope="col">帳號</th>
                                <th scope="col" id="articleReactionTimeTitle">按讚時間</th>
                            </tr>
                        </thead>
                        <tbody id="articleReactionTableBody"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-warning fw-bold text-brown" data-bs-dismiss="modal">關閉</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/css/article-management.css" rel="stylesheet" asp-append-version="true">
}

@section Scripts {
    <script src="~/js/article-management.js" asp-append-version="true"></script>
}
