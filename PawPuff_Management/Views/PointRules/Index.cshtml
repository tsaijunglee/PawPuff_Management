@using PawPuff_Management.Models.ViewModels
@model PointRulesIndexViewModel

@{
    ViewData["Title"] = "規則管理";
    ViewData["CurrentScreen"] = "point-rule-management";
}

<div class="dashboard-content management-screen" id="managementScreen" data-screen-panel="management">
    <section class="soft-panel management-panel">
        <span class="screen-kicker">
            <span class="tiny-paw" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            PawPuff Admin
        </span>
        <h2 class="screen-title" id="managementTitle">規則管理</h2>
        <p class="screen-desc" id="managementDescription">
            設定會員點數取得、扣除與異動規則。
        </p>
        <div class="point-rule-view" id="pointRuleView">
            <div class="member-table-card point-rule-table-card">
                <div class="member-table-toolbar">
                    <strong>
                        <i class="bi bi-coin me-2"></i>
                        點數規則資料表
                    </strong>

                    <span class="member-count">
                        共 @Model.TotalCount 筆
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover member-table point-rule-table align-middle">
                        <thead>
                            <tr>
                                <th scope="col">編號</th>
                                <th scope="col">規則名稱</th>
                                <th scope="col">固定值</th>
                                <th scope="col">預設值</th>
                                <th scope="col">每日上限</th>
                                <th scope="col">描述</th>
                                <th scope="col">操作</th>
                            </tr>
                        </thead>

                        <tbody id="pointRuleTableBody">
                            @if (Model.Rules.Count == 0)
                            {
                                <tr>
                                    <td class="point-rule-empty"
                                        colspan="7">
                                        目前沒有點數規則資料。
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var rule in Model.Rules)
                                {
                                    <tr data-point-rule-row
                                        data-id="@rule.Id"
                                        data-fixed="@rule.IsFixed.ToString().ToLowerInvariant()"
                                        data-default-value="@(rule.DefaultValue?.ToString() ?? string.Empty)"
                                        data-description="@rule.Description">
                                        <td>@rule.Id</td>

                                        <td data-point-rule-cell="name">
                                            @rule.ActionName
                                        </td>

                                        <td>
                                            @if (rule.IsFixed)
                                            {
                                                <span class="point-rule-badge is-fixed">
                                                    是
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="point-rule-badge">
                                                    否
                                                </span>
                                            }
                                        </td>

                                        <td data-point-rule-cell="defaultValue">
                                            @if (rule.DefaultValue.HasValue)
                                            {
                                                @rule.DefaultValue.Value
                                            }
                                            else
                                            {
                                                <span class="point-rule-null"
                                                      aria-label="NULL">
                                                    —
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            @if (rule.DailyLimit.HasValue)
                                            {
                                                @rule.DailyLimit.Value
                                            }
                                            else
                                            {
                                                <span class="point-rule-null"
                                                      aria-label="NULL">
                                                    —
                                                </span>
                                            }
                                        </td>

                                        <td class="point-rule-description"
                                            data-point-rule-cell="description">
                                            @if (!string.IsNullOrWhiteSpace(rule.Description))
                                            {
                                                @rule.Description
                                            }
                                            else
                                            {
                                                <span class="point-rule-null"
                                                      aria-label="NULL">
                                                    —
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            @if (rule.CanEdit)
                                            {
                                                <button class="member-detail-btn point-rule-edit-btn"
                                                        type="button"
                                                        data-point-rule-edit>
                                                    <i class="bi bi-pencil-square"></i>
                                                    編輯
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="point-rule-unavailable">
                                                    不可編輯
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
</div>

<div class="modal fade"
     id="pointRuleEditModal"
     tabindex="-1"
     aria-labelledby="pointRuleEditModalTitle"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content member-form-modal">
            <form id="pointRuleEditForm"
                  data-update-url="@Url.Action("Update", "PointRules")"
                  novalidate>
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title" id="pointRuleEditModalTitle">
                        編輯點數規則
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="關閉">
                    </button>
                </div>

                <div class="modal-body">
                    <input id="pointRuleEditId" type="hidden" />

                    <div class="mb-3">
                        <label class="form-label"
                               for="pointRuleEditName">
                            規則名稱
                        </label>

                        <input class="form-control point-rule-modal-input"
                               id="pointRuleEditName"
                               type="text"
                               readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"
                               for="pointRuleEditValue">
                            預設值
                        </label>

                        <input class="form-control point-rule-modal-input"
                               id="pointRuleEditValue"
                               type="number"
                               min="0"
                               max="2147483647"
                               step="1"
                               required />

                        <div class="invalid-feedback">
                            請輸入大於或等於 0 的整數預設值。
                        </div>
                    </div>

                    <div>
                        <label class="form-label"
                               for="pointRuleEditReason">
                            描述
                        </label>

                        <textarea class="form-control point-rule-modal-textarea"
                                  id="pointRuleEditReason"
                                  rows="4"
                                  maxlength="100"
                                  required
                                  placeholder="請填寫規則描述"></textarea>

                        <div class="invalid-feedback">
                            請填寫 100 個字以內的描述。
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        取消
                    </button>

                    <button type="submit"
                            class="btn btn-warning fw-bold text-brown"
                            id="pointRuleEditSubmit">
                        儲存修改
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/css/point-rule-management.css" rel="stylesheet" asp-append-version="true">
}

@section Scripts {
    <script src="~/js/point-rule-management.js" asp-append-version="true"></script>
}
